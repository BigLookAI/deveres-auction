# deVeres Auction — Environment variables
# Copy this file to .env and fill in the values you need.
# The service runs fully without any of these set (demo mode).

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8003
HOST=0.0.0.0

# ── LLM Email Drafting (optional) ────────────────────────────────────────────
# Point at any vLLM / Ollama / OpenAI-compatible inference server.
# Leave unset to use dry-run template mode (no LLM required).
#
# Ollama (local):   VLLM_URL=http://localhost:11434/api/generate
# vLLM (local):     VLLM_URL=http://localhost:8000/generate
# Remote:           VLLM_URL=https://your-server/generate
VLLM_URL=

# ── Odoo Integration (optional) ──────────────────────────────────────────────
# Only needed when running with --odoo flag or use_odoo=true in /evaluate.
# Leave unset to use bundled JSON sample data (default / recommended for local dev).
#
# ODOO_URL=https://your-instance.odoo.com
# ODOO_DB=your_database_name
# ODOO_USERNAME=your@email.com
# ODOO_PASSWORD=your_api_key

# ── Data paths (optional overrides) ─────────────────────────────────────────
# Defaults to the bundled data/ directory.
# LOTS_PATH=data/sample_upcoming_lots.json
# BIDDERS_PATH=data/sample_bidding_history.json
# PAST_LOTS_PATH=data/sample_past_lots.json

# ── Local Odoo 19 sandbox (odoo-test/ — April-auction test DB restore) ───────
# ODOO_URL=http://localhost:8071
# ODOO_DB=deveres
# ODOO_USERNAME=admin
# ODOO_PASSWORD=<api key from res.users.apikeys — see docs/RECONCILIATION.md>
# RECON_ALLOW_ODOO_WRITE=1
