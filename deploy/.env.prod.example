# deVeres production secrets — copy to deploy/.env.prod and fill in.
# NEVER commit .env.prod. Generate strong values (e.g. `openssl rand -base64 24`).

POSTGRES_PASSWORD=
ODOO_ADMIN_PASSWD=
ODOO_DB=odoo_deveres
ODOO_USERNAME=admin
# API key generated in Odoo (Settings > Users > API Keys) — used as the app's
# ODOO_PASSWORD and as the Bearer key if ODOO_TRANSPORT=json2.
ODOO_API_KEY=
# xmlrpc (default, for the live sale) or json2 (stable/hosted version)
ODOO_TRANSPORT=xmlrpc
# Live Odoo writes are double-gated: this must be 1 AND the push call dry_run:false
RECON_ALLOW_ODOO_WRITE=0

# App HTTP Basic auth (admin can approve/push; viewer is read-only)
RECON_USER=
RECON_PASS=
RECON_VIEWER_USER=
RECON_VIEWER_PASS=

# Backups (deploy/backup.sh)
S3_BUCKET=
RETENTION_DAYS=14
