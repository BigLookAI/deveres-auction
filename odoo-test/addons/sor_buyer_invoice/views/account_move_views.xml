<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form view: Customer Code, Event header placement, document type selector suppression -->
    <record id="account_move_view_form_sor_buyer_invoice" model="ir.ui.view">
        <field name="name">account.move.view.form.sor.buyer.invoice</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Customer Code — partner.ref is not in the native invoice form -->
            <xpath expr="//group[@id='header_left_group']/field[@name='partner_shipping_id']" position="before">
                <field name="partner_ref" string="Customer Code" readonly="1"
                       invisible="move_type not in ('out_invoice', 'out_refund', 'out_receipt')"/>
            </xpath>
            <!-- BUG-06: Event field in header group — previously rendered below notebook -->
            <xpath expr="//group[@id='header_left_group']/field[@name='partner_ref']" position="after">
                <field name="sor_event_id" readonly="1"
                       invisible="move_type not in ('out_invoice', 'out_refund', 'out_receipt')"/>
            </xpath>
            <!-- BUG-10: Suppress document type selector — SOR invoices are always out_invoice;
                 staff have no use for this GL complexity surface (Story 01 AC 02).
                 The widget lives inside <span class="o_form_label"> inside <div class="oe_title">. -->
            <xpath expr="//div[contains(@class,'oe_title')]/span[contains(@class,'o_form_label')]" position="replace"/>
        </field>
    </record>

    <!-- BUG-13: Invoice list — suppress sequence-gap red decoration on SOR buyer invoices.
         SOR buyer invoices use a custom {sequential}/{sale_number} naming format that bypasses
         the AUC journal's native sequence counter, so made_sequence_gap is always True.
         Red decoration alongside a green Paid badge is semantically misleading for staff. -->
    <record id="account_invoice_list_sor_buyer_invoice" model="ir.ui.view">
        <field name="name">account.invoice.list.sor.buyer.invoice</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <!-- Declare sor_event_id so the decoration expression can reference it -->
            <xpath expr="//field[@name='made_sequence_gap']" position="after">
                <field name="sor_event_id" column_invisible="True"/>
            </xpath>
            <!-- Preserve gap warning for non-SOR moves; suppress for buyer invoices -->
            <xpath expr="//field[@name='name'][@widget='char_with_placeholder_field_to_check']" position="attributes">
                <attribute name="decoration-danger">made_sequence_gap and state == 'posted' and not sor_event_id</attribute>
            </xpath>
        </field>
    </record>

    <!-- BUG-14: Restrict Invoices list to out_invoice only — remove out_receipt from domain
         and search_default_out_receipt from context. SOR will never generate Sales Receipts. -->
    <record id="account.action_move_out_invoice" model="ir.actions.act_window">
        <field name="domain">[('move_type', '=', 'out_invoice')]</field>
        <field name="context">{'default_move_type': 'out_invoice'}</field>
    </record>

    <!-- BUG-14 (continued): Remove the Receipts filter option from the invoice search panel.
         The action domain already excludes out_receipt records; the search filter option
         would still show as selectable, which implies receipts are a valid document type here. -->
    <record id="account_invoice_search_sor_buyer_invoice" model="ir.ui.view">
        <field name="name">account.invoice.search.sor.buyer.invoice</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='out_receipt']" position="replace"/>
        </field>
    </record>
</odoo>
