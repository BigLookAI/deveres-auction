<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="sor_event_view_form" model="ir.ui.view">
        <field name="name">sor.event.form</field>
        <field name="model">sor.event</field>
        <field name="arch" type="xml">
            <form string="Event">
                <header>
                    <button name="action_publish" string="Publish" type="object"
                            invisible="status != 'draft'" class="btn-primary"/>
                    <button name="action_activate" string="Activate" type="object"
                            invisible="status != 'published'" class="btn-primary"/>
                    <button name="action_close" string="Close" type="object"
                            invisible="status != 'active'"/>
                    <button name="action_archive_event" string="Archive" type="object"
                            invisible="status != 'closed'"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,published,active,closed,archived"/>
                </header>
                <sheet>
                    <div name="button_box" class="oe_button_box"/>
                    <group>
                        <group string="Identification">
                            <field name="name"/>
                            <field name="event_type"/>
                            <field name="company_id" groups="base.group_multi_company" readonly="1"/>
                        </group>
                        <group string="Schedule">
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="venue_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="internal_notes" string="Internal Notes">
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="sor_event_view_list" model="ir.ui.view">
        <field name="name">sor.event.list</field>
        <field name="model">sor.event</field>
        <field name="arch" type="xml">
            <list string="Events">
                <field name="name"/>
                <field name="event_type"/>
                <field name="status"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="venue_id"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="sor_event_view_search" model="ir.ui.view">
        <field name="name">sor.event.search</field>
        <field name="model">sor.event</field>
        <field name="arch" type="xml">
            <search string="Search Events">
                <field name="name" string="Event Name"/>
                <filter string="Exhibition" name="filter_exhibition"
                        domain="[('event_type', '=', 'exhibition')]"/>
                <filter string="Auction" name="filter_auction"
                        domain="[('event_type', '=', 'auction')]"/>
                <separator/>
                <filter string="Draft" name="filter_draft"
                        domain="[('status', '=', 'draft')]"/>
                <filter string="Published" name="filter_published"
                        domain="[('status', '=', 'published')]"/>
                <filter string="Active" name="filter_active"
                        domain="[('status', '=', 'active')]"/>
                <filter string="Closed" name="filter_closed"
                        domain="[('status', '=', 'closed')]"/>
                <filter string="Archived" name="filter_archived"
                        domain="[('status', '=', 'archived')]"/>
                <group>
                    <filter string="Type" name="groupby_type" context="{'group_by': 'event_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="sor_event_action" model="ir.actions.act_window">
        <field name="name">Events</field>
        <field name="res_model">sor.event</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('company_id', '=', allowed_company_ids[0])]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first event
            </p>
            <p>
                Events track exhibitions and auctions from planning through to archiving.
            </p>
        </field>
    </record>

    <!-- Developer Utility Menu — under Settings > Technical > SOR -->
    <!-- sor_events is infrastructure: no standalone user-facing production menu -->
    <menuitem id="menu_sor_events"
              name="Events"
              action="sor_event_action"
              parent="sor_technical_menu.menu_sor_technical_root"
              sequence="20"
              groups="base.group_no_one"/>

</odoo>
