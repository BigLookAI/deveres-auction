<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="sor_lot_view_form" model="ir.ui.view">
        <field name="name">sor.lot.form</field>
        <field name="model">sor.lot</field>
        <field name="arch" type="xml">
            <form string="Lot">
                <header>
                    <button name="action_catalogue" string="Catalogue"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_mark_sold" string="Mark Sold"
                            type="object" class="btn-primary"
                            confirm="Mark this lot as Sold? This cannot be undone."
                            invisible="state not in ('catalogued', 'live')"/>
                    <button name="action_mark_passed" string="Mark Passed"
                            type="object"
                            confirm="Mark this lot as Passed? This cannot be undone."
                            invisible="state not in ('catalogued', 'live')"/>
                    <button name="action_withdraw" string="Withdraw"
                            type="object"
                            confirm="Withdraw this lot? This cannot be undone."
                            invisible="state not in ('draft', 'catalogued')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,catalogued,sold,passed,withdrawn"/>
                </header>
                <sheet>
                    <group>
                        <group string="Identification">
                            <field name="lot_reference" readonly="1"/>
                            <field name="lot_number" readonly="state != 'draft'"/>
                            <field name="lot_suffix" readonly="state != 'draft'"/>
                            <label for="product_id"/>
                            <div class="d-flex align-items-center gap-2">
                                <field name="product_id" nolabel="1"
                                       context="{'suppress_product_code': True}"
                                       options="{'no_open': True}"
                                       readonly="state != 'draft'"/>
                                <button name="action_open_product" type="object"
                                        icon="fa-external-link"
                                        title="Open Product"
                                        class="btn btn-link p-0"
                                        invisible="not product_id"/>
                            </div>
                            <field name="company_id" groups="base.group_multi_company" readonly="1"/>
                        </group>
                        <group string="Financial" name="financial">
                            <!-- currency_id declared invisible — required by Monetary widgets
                                 for currency resolution but not shown to users -->
                            <field name="currency_id" invisible="1"/>
                            <field name="estimate_low" readonly="state != 'draft'"/>
                            <field name="estimate_high" readonly="state != 'draft'"/>
                            <field name="reserve_price" readonly="state != 'draft'"/>
                            <field name="no_reserve" readonly="state != 'draft'"/>
                            <field name="starting_bid" readonly="state != 'draft'"/>
                            <field name="hammer_price"/>
                            <field name="break_even_value" readonly="1"/>
                        </group>
                    </group>
                    <!-- D2 bridge injection point: auction_id and fee tabs go here -->
                    <notebook>
                        <page name="internal_notes" string="Internal Notes">
                            <field name="internal_notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="sor_lot_view_list" model="ir.ui.view">
        <field name="name">sor.lot.list</field>
        <field name="model">sor.lot</field>
        <field name="arch" type="xml">
            <list string="Lots">
                <!-- currency_id declared optional="hide" — required by Monetary widgets
                     for currency resolution; hidden by default but field data is
                     fetched so Monetary widget can resolve the currency per row.
                     column_invisible="1" removes the field from the DOM entirely,
                     breaking Monetary widget resolution. optional="hide" keeps the
                     field in the arch while suppressing the column. -->
                <field name="currency_id" optional="hide"/>
                <field name="lot_reference"/>
                <field name="lot_number"/>
                <field name="lot_suffix"/>
                <field name="product_id" context="{'suppress_product_code': True}"/>
                <field name="state"/>
                <field name="estimate_low"/>
                <field name="estimate_high"/>
                <field name="reserve_price"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="sor_lot_view_search" model="ir.ui.view">
        <field name="name">sor.lot.search</field>
        <field name="model">sor.lot</field>
        <field name="arch" type="xml">
            <search string="Search Lots">
                <field name="lot_reference" string="Lot Reference"/>
                <field name="lot_number" string="Lot Number"
                       filter_domain="[('lot_number', '=', self)]"/>
                <field name="product_id" string="Product"/>
                <separator/>
                <filter string="Draft" name="filter_draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Catalogued" name="filter_catalogued"
                        domain="[('state', '=', 'catalogued')]"/>
                <filter string="Live" name="filter_live"
                        domain="[('state', '=', 'live')]"/>
                <filter string="Sold" name="filter_sold"
                        domain="[('state', '=', 'sold')]"/>
                <filter string="Passed" name="filter_passed"
                        domain="[('state', '=', 'passed')]"/>
                <filter string="Withdrawn" name="filter_withdrawn"
                        domain="[('state', '=', 'withdrawn')]"/>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="sor_lot_action" model="ir.actions.act_window">
        <field name="name">Lots</field>
        <field name="res_model">sor.lot</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('company_id', '=', allowed_company_ids[0])]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first lot
            </p>
            <p>
                Lots are the individual catalogue entries for a sale.
                Each lot links a product to its estimates, reserve price, and sale outcome.
            </p>
        </field>
    </record>

    <menuitem id="menu_sor_lots_root"
              name="Lots"
              sequence="120"/>

    <menuitem id="menu_sor_lots"
              name="Lots"
              parent="menu_sor_lots_root"
              action="sor_lot_action"
              sequence="30"
              groups="base.group_user"/>

</odoo>
