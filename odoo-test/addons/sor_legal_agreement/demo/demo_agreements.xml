<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="demo_agreement_draft" model="sor.agreement">
            <field name="agreement_type">base</field>
            <field name="primary_partner_id" ref="sor_contact_roles.demo_collector_john"/>
            <field name="date_start" eval="(datetime.now() + timedelta(days=30)).strftime('%Y-%m-%d')"/>
            <field name="date_end" eval="(datetime.now() + timedelta(days=395)).strftime('%Y-%m-%d')"/>
            <field name="state">draft</field>
        </record>

        <record id="demo_agreement_pending" model="sor.agreement">
            <field name="agreement_type">base</field>
            <field name="primary_partner_id" ref="sor_contact_roles.demo_collector_bridget"/>
            <field name="date_start" eval="(datetime.now() + timedelta(days=14)).strftime('%Y-%m-%d')"/>
            <field name="date_end" eval="(datetime.now() + timedelta(days=379)).strftime('%Y-%m-%d')"/>
            <field name="date_sent_for_signature" eval="(datetime.now() - timedelta(days=5)).strftime('%Y-%m-%d')"/>
            <field name="state">pending_signature</field>
        </record>

        <record id="demo_agreement_active" model="sor.agreement">
            <field name="agreement_type">base</field>
            <field name="primary_partner_id" ref="sor_contact_roles.demo_institution_rha"/>
            <field name="date_start" eval="(datetime.now() - timedelta(days=90)).strftime('%Y-%m-%d')"/>
            <field name="date_end" eval="(datetime.now() + timedelta(days=275)).strftime('%Y-%m-%d')"/>
            <field name="state">active</field>
        </record>

        <record id="demo_agreement_closed" model="sor.agreement">
            <field name="agreement_type">base</field>
            <field name="primary_partner_id" ref="sor_contact_roles.demo_dealer_william"/>
            <field name="date_start" eval="(datetime.now() - timedelta(days=400)).strftime('%Y-%m-%d')"/>
            <field name="date_end" eval="(datetime.now() - timedelta(days=35)).strftime('%Y-%m-%d')"/>
            <field name="state">closed</field>
        </record>
    </data>
</odoo>
