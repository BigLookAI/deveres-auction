<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sor_lot_form_inherit_auction_docs" model="ir.ui.view">
        <field name="name">sor.lot.form.inherit.auction.docs</field>
        <field name="model">sor.lot</field>
        <field name="inherit_id" ref="sor_lotting.sor_lot_view_form"/>
        <field name="arch" type="xml">
            <!-- consignor_id is declared in the base sor_lot form (sor_lotting owns the field).
                 Apply auction-docs-specific attributes: readonly state lock and no-create options.
                 no_open suppresses built-in nav link — preserves form context. -->
            <xpath expr="//field[@name='consignor_id']" position="attributes">
                <attribute name="readonly">state not in ('draft', 'catalogued')</attribute>
                <attribute name="options">{'no_create': True, 'no_quick_create': True}</attribute>
            </xpath>
            <!-- Place auction-docs-specific fields after consignor_id. -->
            <xpath expr="//field[@name='consignor_id']" position="after">
                <field name="consignor_company"
                       readonly="state not in ('draft', 'catalogued')"/>
                <field name="sor_receipt_number"/>
                <field name="vat_margin_scheme"/>
            </xpath>
        </field>
    </record>

    <!-- List view: Consignor optional column, hidden by default. -->
    <record id="view_sor_lot_list_inherit_auction_docs" model="ir.ui.view">
        <field name="name">sor.lot.list.inherit.auction.docs</field>
        <field name="model">sor.lot</field>
        <field name="inherit_id" ref="sor_lotting.sor_lot_view_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='reserve_price']" position="after">
                <field name="consignor_id" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
