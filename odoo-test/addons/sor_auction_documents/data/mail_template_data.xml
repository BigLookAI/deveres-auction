<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="mail_template_sor_pre_sale_advice" model="mail.template">
            <field name="name">Pre-Sale Advice: Sending</field>
            <field name="model_id" ref="sor_auction_documents.model_sor_pre_sale_advice"/>
            <field name="email_from">{{ object.company_id.email or user.email_formatted }}</field>
            <field name="use_default_to" eval="False"/>
            <field name="partner_to">{{ object.consignor_id.id }}</field>
            <field name="subject">Pre-Sale Advice — {{ object.event_id.name }}</field>
            <field name="description">Sent to consignors with their Pre-Sale Advice attached</field>
            <field name="report_template_ids" eval="[(6, 0, [ref('sor_auction_documents.action_report_sor_pre_sale_advice')])]"/>
            <field name="body_html" type="html">
                <div>
                    <p>Dear <t t-out="object.consignor_id.name"/>,</p>
                    <p>Please find your Pre-Sale Advice attached.</p>
                </div>
            </field>
        </record>

        <record id="mail_template_sor_post_sale_advice" model="mail.template">
            <field name="name">Post-Sale Advice: Sending</field>
            <field name="model_id" ref="sor_auction_documents.model_sor_post_sale_advice"/>
            <field name="email_from">{{ object.company_id.email or user.email_formatted }}</field>
            <field name="use_default_to" eval="False"/>
            <field name="partner_to">{{ object.consignor_id.id }}</field>
            <field name="subject">Post-Sale Advice — {{ object.event_id.name }}</field>
            <field name="description">Sent to consignors with their Post-Sale Advice attached</field>
            <field name="report_template_ids" eval="[(6, 0, [ref('sor_auction_documents.action_report_sor_post_sale_advice')])]"/>
            <field name="body_html" type="html">
                <div>
                    <p>Dear <t t-out="object.consignor_id.name"/>,</p>
                    <p>Please find your Post-Sale Advice attached.</p>
                </div>
            </field>
        </record>

        <record id="mail_template_sor_vendor_settlement" model="mail.template">
            <field name="name">Vendor Settlement Statement: Sending</field>
            <field name="model_id" ref="sor_auction_documents.model_sor_vendor_settlement"/>
            <field name="email_from">{{ object.company_id.email or user.email_formatted }}</field>
            <field name="use_default_to" eval="False"/>
            <field name="partner_to">{{ object.consignor_id.id }}</field>
            <field name="subject">Vendor Settlement Statement — {{ object.event_id.name }}</field>
            <field name="description">Sent to consignors with their Vendor Settlement Statement attached</field>
            <field name="report_template_ids" eval="[(6, 0, [ref('sor_auction_documents.action_report_sor_vendor_settlement')])]"/>
            <field name="body_html" type="html">
                <div>
                    <p>Dear <t t-out="object.consignor_id.name"/>,</p>
                    <p>Please find your Vendor Settlement Statement for <t t-out="object.event_id.name"/> attached.</p>
                </div>
            </field>
        </record>
    </data>
</odoo>
