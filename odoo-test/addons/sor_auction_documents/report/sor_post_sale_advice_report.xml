<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_sor_post_sale_advice" model="ir.actions.report">
        <field name="name">Post-Sale Advice</field>
        <field name="model">sor.post.sale.advice</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sor_auction_documents.report_sor_post_sale_advice</field>
        <field name="report_file">sor_auction_documents.report_sor_post_sale_advice</field>
        <field name="print_report_name">'Post-Sale Advice - %s' % object.name</field>
    </record>

    <template id="report_sor_post_sale_advice">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="font-size:13px;">
                        <h4>Post-Sale Advice (<t t-out="doc.name"/>)</h4>

                        <!-- Consignor and event details. Column split matches web.external_layout_bold's
                             own header address block (col-6 / col-5 offset-1) so this row lines up
                             horizontally with the company address block above it. -->
                        <div class="row mb-4">
                            <div class="col-6">
                                <t t-if="doc.consignor_id.ref">
                                    <strong>Seller Reference:</strong>
                                    <t t-out="doc.consignor_id.ref"/><br/>
                                </t>
                                <t t-out="doc.consignor_id.name"/><br/>
                                <t t-if="doc.consignor_id.street">
                                    <t t-out="doc.consignor_id.street"/><br/>
                                </t>
                                <t t-if="doc.consignor_id.street2">
                                    <t t-out="doc.consignor_id.street2"/><br/>
                                </t>
                                <t t-if="doc.consignor_id.city">
                                    <t t-out="doc.consignor_id.city"/>
                                </t>
                                <t t-if="doc.consignor_id.state_id">
                                    <t t-if="doc.consignor_id.city">, </t>
                                    <t t-out="doc.consignor_id.state_id.name"/>
                                </t>
                                <t t-if="doc.consignor_id.zip">
                                    <t t-if="doc.consignor_id.city or doc.consignor_id.state_id">, </t>
                                    <t t-out="doc.consignor_id.zip"/>
                                </t>
                                <t t-if="doc.consignor_id.vat">
                                    <br/><strong>VAT:</strong> <t t-out="doc.consignor_id.vat"/>
                                </t>
                            </div>
                            <div class="col-5 offset-1">
                                <strong>Sale:</strong>
                                <t t-out="doc.event_id.name"/>
                                <t t-if="doc.event_id.sale_number">
                                    (<t t-out="doc.event_id.sale_number"/>)
                                </t>
                                <t t-if="doc.event_id.date_end">
                                    <br/>
                                    <strong>End Date:</strong>
                                    <t t-out="doc.event_id.date_end" t-options="{'widget': 'date'}"/>
                                </t>
                            </div>
                        </div>

                        <!-- Top content block -->
                        <t t-if="doc.company_id.posa_content_top">
                            <div class="mb-4">
                                <t t-out="doc.company_id.posa_content_top"/>
                            </div>
                        </t>

                        <!-- Results table: 7 columns — Lot No | Receipt No | Description | Reserve | Hammer | VAT | Total -->
                        <t t-set="posa_total_hammer"
                           t-value="sum(0.0 if lot.state == 'passed' else lot.hammer_price for lot in doc.lot_ids)"/>
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th class="text-center" style="font-weight:bold; text-transform:none !important; white-space:nowrap;">Lot no</th>
                                    <th style="font-weight:bold; text-transform:none !important; white-space:nowrap;">Receipt no</th>
                                    <th style="font-weight:bold; text-transform:none !important; white-space:nowrap;">Description</th>
                                    <th class="text-end" style="font-weight:bold; text-transform:none !important; white-space:nowrap;">Reserve</th>
                                    <th class="text-end" style="font-weight:bold; text-transform:none !important; white-space:nowrap;">Hammer</th>
                                    <th class="text-end" style="font-weight:bold; text-transform:none !important; white-space:nowrap;">VAT</th>
                                    <th class="text-end" style="font-weight:bold; text-transform:none !important; white-space:nowrap;">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.lot_ids.sorted('lot_number')" t-as="lot">
                                    <tr>
                                        <td class="text-center"><t t-out="lot.lot_number or ''"/></td>
                                        <td><t t-out="lot.sor_receipt_number or ''"/></td>
                                        <td>
                                            <t t-if="lot.product_id">
                                                <t t-out="lot.product_id.name"/>
                                            </t>
                                            <t t-if="not lot.product_id and lot.lot_description">
                                                <t t-out="lot.lot_description"/>
                                            </t>
                                        </td>
                                        <td class="text-end">
                                            <t t-out="lot.reserve_price"
                                               t-options="{'widget': 'monetary', 'display_currency': lot.currency_id}"/>
                                        </td>
                                        <!-- Hammer: passed lots show 0.00 -->
                                        <t t-if="lot.state == 'passed'">
                                            <td class="text-end">
                                                <t t-out="0.0"
                                                   t-options="{'widget': 'monetary', 'display_currency': lot.currency_id}"/>
                                            </td>
                                            <td class="text-end">—</td>
                                            <td class="text-end">—</td>
                                        </t>
                                        <!-- Margin scheme lots: VAT = €0.00, Total = hammer -->
                                        <t t-elif="lot.vat_margin_scheme">
                                            <td class="text-end">
                                                <t t-out="lot.hammer_price"
                                                   t-options="{'widget': 'monetary', 'display_currency': lot.currency_id}"/>
                                            </td>
                                            <td class="text-end">
                                                <t t-out="lot.hammer_price * 0"
                                                   t-options="{'widget': 'monetary', 'display_currency': lot.currency_id}"/>
                                            </td>
                                            <td class="text-end">
                                                <t t-out="lot.hammer_price"
                                                   t-options="{'widget': 'monetary', 'display_currency': lot.currency_id}"/>
                                            </td>
                                        </t>
                                        <!-- Standard sold lots: VAT and Total not applicable -->
                                        <t t-else="">
                                            <td class="text-end">
                                                <t t-out="lot.hammer_price"
                                                   t-options="{'widget': 'monetary', 'display_currency': lot.currency_id}"/>
                                            </td>
                                            <td class="text-end">—</td>
                                            <td class="text-end">—</td>
                                        </t>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="6" class="text-end" style="font-weight:bold;">Total</td>
                                    <td class="text-end" style="font-weight:bold;">
                                        <t t-out="posa_total_hammer"
                                           t-options="{'widget': 'monetary', 'display_currency': doc.company_id.currency_id}"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- Bottom content block -->
                        <t t-if="doc.company_id.posa_content_bottom">
                            <div class="mt-4">
                                <t t-out="doc.company_id.posa_content_bottom"/>
                            </div>
                        </t>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
