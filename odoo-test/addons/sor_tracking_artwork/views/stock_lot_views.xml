<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- stock.lot form overrides for SOR artwork serial tracking context.
         Applied when the modal is used to create a serial number for a unique-object
         artwork movement. display_complete=False when the lot has no id (new lot);
         True for existing lots viewed directly — used as the visibility proxy. -->
    <record id="view_lot_form_sor_tracking_artwork" model="ir.ui.view">
        <field name="name">stock.lot.form.sor.tracking.artwork</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form"/>
        <field name="arch" type="xml">
            <!-- Relabel serial field — SOR reserves "Lot" for sor.lot (auction catalogue items) -->
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="string">Serial Number</attribute>
            </xpath>
            <!-- Suppress Information group in new-lot context (redundant when product is
                 pre-filled from the movement and all other fields are empty) -->
            <xpath expr="//group[field[@name='ref']]" position="attributes">
                <attribute name="invisible">not display_complete</attribute>
            </xpath>
            <!-- Suppress Inventory group in new-lot context (qty/location not yet
                 meaningful for a serial that hasn't been validated into stock) -->
            <xpath expr="//group[@name='inventory_group']" position="attributes">
                <attribute name="invisible">not display_complete</attribute>
            </xpath>
            <!-- Replace default dialog footer (Save & New + Save & Close + Discard) with
                 Save + Discard only. "Save & New" would allow creating multiple serials
                 for a single artwork movement line, violating the unique-object paradigm. -->
            <xpath expr="//form" position="inside">
                <footer>
                    <button string="Save" class="btn-primary" special="save" data-hotkey="s"/>
                    <button string="Discard" class="btn-secondary" special="cancel" data-hotkey="j"/>
                </footer>
            </xpath>
        </field>
    </record>

</odoo>
