<?xml version="1.0" encoding="utf-8"?>
<!-- UI manifestation records for the unique_object paradigm rules.
     Each record is one physical Odoo UI element suppressed by its parent rule.
     element_key here is the Odoo field/page/button name targeted by the XPath,
     distinct from the parent rule's feature key.
     noupdate="0": upgrade restores any accidentally deleted records. -->
<odoo>
    <data noupdate="1">

        <!-- forecast_button -->
        <record id="manifestation_forecast_btn_form" model="sor.asset.paradigm.rule.manifestation">
            <field name="rule_id" ref="rule_unique_object_forecast_button"/>
            <field name="element_name">Forecasted Qty Smart Button</field>
            <field name="element_key">action_product_tmpl_forecast_report</field>
            <field name="ui_element_type">Smart Button</field>
            <field name="ui_location">Product Template Form > Smart Buttons</field>
        </record>

        <!-- reorder_button -->
        <record id="manifestation_reorder_btn_form" model="sor.asset.paradigm.rule.manifestation">
            <field name="rule_id" ref="rule_unique_object_reorder_button"/>
            <field name="element_name">Reorder Rules Smart Button</field>
            <field name="element_key">action_view_orderpoints</field>
            <field name="ui_element_type">Smart Button</field>
            <field name="ui_location">Product Template Form > Smart Buttons</field>
        </record>

        <!-- moves_button -->
        <record id="manifestation_moves_btn_form" model="sor.asset.paradigm.rule.manifestation">
            <field name="rule_id" ref="rule_unique_object_moves_button"/>
            <field name="element_name">Moves In/Out Smart Button</field>
            <field name="element_key">action_view_stock_move_lines</field>
            <field name="ui_element_type">Smart Button</field>
            <field name="ui_location">Product Template Form > Smart Buttons</field>
        </record>

        <!-- putaway_button -->
        <record id="manifestation_putaway_btn_form" model="sor.asset.paradigm.rule.manifestation">
            <field name="rule_id" ref="rule_unique_object_putaway_button"/>
            <field name="element_name">Putaway Rules Smart Button</field>
            <field name="element_key">action_view_related_putaway_rules</field>
            <field name="ui_element_type">Smart Button</field>
            <field name="ui_location">Product Template Form > Smart Buttons</field>
        </record>

        <!-- storage_capacity_button -->
        <record id="manifestation_storage_cap_btn_form" model="sor.asset.paradigm.rule.manifestation">
            <field name="rule_id" ref="rule_unique_object_storage_capacity_button"/>
            <field name="element_name">Storage Capacities Smart Button</field>
            <field name="element_key">action_view_storage_category_capacity</field>
            <field name="ui_element_type">Smart Button</field>
            <field name="ui_location">Product Template Form > Smart Buttons</field>
        </record>

        <!-- qty_available_field -->
        <record id="manifestation_qty_available_form" model="sor.asset.paradigm.rule.manifestation">
            <field name="rule_id" ref="rule_unique_object_qty_available_field"/>
            <field name="element_name">Qty Available Field</field>
            <field name="element_key">qty_available</field>
            <field name="ui_element_type">Field</field>
            <field name="ui_location">Product Template Form > General Information Tab (stock)</field>
        </record>

        <!-- qty_column — three UI elements -->
        <record id="manifestation_qty_col_list_qty" model="sor.asset.paradigm.rule.manifestation">
            <field name="rule_id" ref="rule_unique_object_qty_column"/>
            <field name="element_name">Qty Available Column</field>
            <field name="element_key">qty_available</field>
            <field name="ui_element_type">List Column</field>
            <field name="ui_location">Product Template List View</field>
        </record>
        <record id="manifestation_qty_col_list_forecast" model="sor.asset.paradigm.rule.manifestation">
            <field name="rule_id" ref="rule_unique_object_qty_column"/>
            <field name="element_name">Forecasted Qty Column</field>
            <field name="element_key">virtual_available</field>
            <field name="ui_element_type">List Column</field>
            <field name="ui_location">Product Template List View</field>
        </record>
        <record id="manifestation_qty_col_kanban" model="sor.asset.paradigm.rule.manifestation">
            <field name="rule_id" ref="rule_unique_object_qty_column"/>
            <field name="element_name">On Hand Quantity</field>
            <field name="element_key">qty_available</field>
            <field name="ui_element_type">Kanban Card Element</field>
            <field name="ui_location">Product Kanban Card</field>
        </record>

        <!-- operations_group -->
        <record id="manifestation_operations_group_form" model="sor.asset.paradigm.rule.manifestation">
            <field name="rule_id" ref="rule_unique_object_operations_group"/>
            <field name="element_name">Operations Group</field>
            <field name="element_key">operations</field>
            <field name="ui_element_type">Field Group</field>
            <field name="ui_location">Product Template Form > General Information Tab (stock)</field>
        </record>

        <!-- replenish_action -->
        <record id="manifestation_replenish_form" model="sor.asset.paradigm.rule.manifestation">
            <field name="rule_id" ref="rule_unique_object_replenish_action"/>
            <field name="element_name">Replenish Action</field>
            <field name="element_key">action_replenishment</field>
            <field name="ui_element_type">Action Menu Item</field>
            <field name="ui_location">Product Template Form > Action Menu (⚙)</field>
        </record>

        <!-- odoo_product_type_field -->
        <record id="manifestation_odoo_type_form" model="sor.asset.paradigm.rule.manifestation">
            <field name="rule_id" ref="rule_unique_object_odoo_product_type_field"/>
            <field name="element_name">Product Type Field</field>
            <field name="element_key">type</field>
            <field name="ui_element_type">Field</field>
            <field name="ui_location">Product Template Form > General Information Tab</field>
        </record>

        <!-- product_type_field -->
        <record id="manifestation_product_type_form" model="sor.asset.paradigm.rule.manifestation">
            <field name="rule_id" ref="rule_unique_object_product_type_field"/>
            <field name="element_name">SOR Type Field</field>
            <field name="element_key">product_type</field>
            <field name="ui_element_type">Field</field>
            <field name="ui_location">Product Template Form > General Information Tab</field>
        </record>

        <!-- track_inventory_field -->
        <record id="manifestation_track_inv_form" model="sor.asset.paradigm.rule.manifestation">
            <field name="rule_id" ref="rule_unique_object_track_inventory_field"/>
            <field name="element_name">Track Inventory Checkbox</field>
            <field name="element_key">is_storable</field>
            <field name="ui_element_type">Field</field>
            <field name="ui_location">Product Template Form > General Information Tab</field>
        </record>

        <!-- inventory_tab -->
        <record id="manifestation_inventory_tab_form" model="sor.asset.paradigm.rule.manifestation">
            <field name="rule_id" ref="rule_unique_object_inventory_tab"/>
            <field name="element_name">Inventory Tab</field>
            <field name="element_key">inventory</field>
            <field name="ui_element_type">Form Tab</field>
            <field name="ui_location">Product Template Form</field>
        </record>

        <!-- odoo_product_type_field — search view (static) -->
        <record id="manifestation_odoo_type_search_goods" model="sor.asset.paradigm.rule.manifestation">
            <field name="rule_id" ref="rule_unique_object_odoo_product_type_field"/>
            <field name="element_name">Goods Search Filter</field>
            <field name="element_key">goods</field>
            <field name="ui_element_type">Search Filter</field>
            <field name="ui_location">Product Template Search Bar > Filters</field>
            <field name="is_static" eval="True"/>
        </record>
        <record id="manifestation_odoo_type_search_services" model="sor.asset.paradigm.rule.manifestation">
            <field name="rule_id" ref="rule_unique_object_odoo_product_type_field"/>
            <field name="element_name">Services Search Filter</field>
            <field name="element_key">services</field>
            <field name="ui_element_type">Search Filter</field>
            <field name="ui_location">Product Template Search Bar > Filters</field>
            <field name="is_static" eval="True"/>
        </record>
        <record id="manifestation_odoo_type_search_combo" model="sor.asset.paradigm.rule.manifestation">
            <field name="rule_id" ref="rule_unique_object_odoo_product_type_field"/>
            <field name="element_name">Combo Search Filter</field>
            <field name="element_key">combo</field>
            <field name="ui_element_type">Search Filter</field>
            <field name="ui_location">Product Template Search Bar > Filters</field>
            <field name="is_static" eval="True"/>
        </record>
        <record id="manifestation_odoo_type_search_groupby" model="sor.asset.paradigm.rule.manifestation">
            <field name="rule_id" ref="rule_unique_object_odoo_product_type_field"/>
            <field name="element_name">Product Type Group By</field>
            <field name="element_key">group_by_type</field>
            <field name="ui_element_type">Search Group By</field>
            <field name="ui_location">Product Template Search Bar > Group By</field>
            <field name="is_static" eval="True"/>
        </record>

        <!-- product_type_field — search view (static) -->
        <record id="manifestation_product_type_search_groupby" model="sor.asset.paradigm.rule.manifestation">
            <field name="rule_id" ref="rule_unique_object_product_type_field"/>
            <field name="element_name">Type Group By</field>
            <field name="element_key">group_product_type</field>
            <field name="ui_element_type">Search Group By</field>
            <field name="ui_location">Product Template Search Bar > Group By</field>
            <field name="is_static" eval="True"/>
        </record>

    </data>
</odoo>
