<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Viewing Locations (stock.warehouse records).
             partner_id is required by SorViewingLocation constraint.
             Using main company partner as the address for demo simplicity. -->
        <record id="demo_location_main_gallery" model="stock.warehouse">
            <field name="name">Main Gallery</field>
            <field name="code">MAIN</field>
            <field name="partner_id" ref="base.res_partner_1"/>
        </record>

        <record id="demo_location_secondary_space" model="stock.warehouse">
            <field name="name">Secondary Space</field>
            <field name="code">SEC</field>
            <field name="partner_id" ref="base.res_partner_1"/>
        </record>

        <record id="demo_location_collection_storage" model="stock.warehouse">
            <field name="name">Collection Storage</field>
            <field name="code">STOR</field>
            <field name="partner_id" ref="base.res_partner_1"/>
        </record>
    </data>
</odoo>
