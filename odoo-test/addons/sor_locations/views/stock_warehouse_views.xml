<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form view: relabel stock.warehouse as "Viewing Location" in SOR context.
         No mode="primary" — applied globally within SOR (intentional: all warehouses
         in SOR are Viewing Locations). -->
    <record id="view_viewing_location_form" model="ir.ui.view">
        <field name="name">sor.viewing.location.form</field>
        <field name="model">stock.warehouse</field>
        <field name="inherit_id" ref="stock.view_warehouse"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="attributes">
                <attribute name="string">Viewing Location</attribute>
            </xpath>
        </field>
    </record>

    <!-- List view: relabel stock.warehouse list as "Viewing Locations". -->
    <record id="view_viewing_location_list" model="ir.ui.view">
        <field name="name">sor.viewing.location.list</field>
        <field name="model">stock.warehouse</field>
        <field name="inherit_id" ref="stock.view_warehouse_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="string">Viewing Locations</attribute>
            </xpath>
        </field>
    </record>

    <!-- Window action for Viewing Locations (SOR entry point). -->
    <record id="action_viewing_location_form" model="ir.actions.act_window">
        <field name="name">Viewing Locations</field>
        <field name="res_model">stock.warehouse</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Viewing Location
            </p>
            <p>
                A Viewing Location represents a physical gallery, auction room,
                or collection building where artworks are displayed or stored.
                Each Viewing Location can contain multiple Rooms.
            </p>
        </field>
    </record>

</odoo>
