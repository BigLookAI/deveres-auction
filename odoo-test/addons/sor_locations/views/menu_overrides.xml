<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Hide standard Warehouses and Locations menus while sor_locations is
         installed. Viewing Locations and Rooms replace them in the SOR UI.
         Note: ir.ui.menu does not expose groups_id as a writable field in
         Odoo 19, so group-based visibility control via <record> is not
         available. active=False is the correct approach.
         Restored by uninstall_hook when this module is removed. -->

    <record id="stock.menu_action_warehouse_form" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <record id="stock.menu_action_location_form" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

</odoo>
