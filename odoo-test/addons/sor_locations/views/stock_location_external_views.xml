<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view for External Locations: customer-type locations. -->
    <record id="view_external_location_list" model="ir.ui.view">
        <field name="name">sor.external.location.list</field>
        <field name="model">stock.location</field>
        <field name="arch" type="xml">
            <list string="External Locations">
                <field name="name" string="External Location"/>
                <field name="location_id" string="Location Group"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- Search view for External Locations. -->
    <record id="view_external_location_search" model="ir.ui.view">
        <field name="name">sor.external.location.search</field>
        <field name="model">stock.location</field>
        <field name="arch" type="xml">
            <search string="External Locations">
                <field name="name" string="Location Name"/>
                <filter string="External Locations"
                        name="filter_external"
                        domain="[('usage', '=', 'customer')]"/>
                <separator/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Form view (primary) for External Locations: inherits stock location form.
         mode=primary keeps this separate from the standard Locations form.
         location_id is restricted to view-type parent locations; readonly on
         existing records (readonly="id") so it can be defaulted on new records. -->
    <record id="view_external_location_form" model="ir.ui.view">
        <field name="name">sor.external.location.form</field>
        <field name="model">stock.location</field>
        <field name="inherit_id" ref="stock.view_location_form"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <!-- Relabel location_id and restrict to view-type locations only. -->
            <xpath expr="//h2/field[@name='location_id']" position="attributes">
                <attribute name="string">Location Group</attribute>
                <attribute name="domain">[('usage', '=', 'view')]</attribute>
                <attribute name="readonly">id</attribute>
            </xpath>
            <!-- Make usage (Location Type) readonly — External locations are always Customer type. -->
            <xpath expr="//group[@name='additional_info']/field[@name='usage']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
        </field>
    </record>

    <!-- Window action: scoped to customer (External) locations. -->
    <record id="action_external_location_form" model="ir.actions.act_window">
        <field name="name">External Locations</field>
        <field name="res_model">stock.location</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('usage', '=', 'customer')]</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_external_location_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_external_location_form')}),
        ]"/>
        <field name="search_view_id" ref="view_external_location_search"/>
        <field name="context">{'default_usage': 'customer'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first External Location
            </p>
            <p>
                External locations represent where artworks are held outside the gallery:
                at a buyer, borrower, institution, or in transit.
                Install SOR Contact Roles to link locations directly to customer contacts.
            </p>
        </field>
    </record>

</odoo>
