<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sor_movement_location_confirm_form" model="ir.ui.view">
        <field name="name">sor.movement.location.confirm.form</field>
        <field name="model">sor.movement.location.confirm</field>
        <field name="arch" type="xml">
            <form string="Confirm Location Update">
                <div class="alert alert-warning mb-0" role="alert">
                    This movement will update the current location of one or more
                    products. Do you want to proceed?
                </div>
                <footer>
                    <button string="Proceed" name="action_confirm"
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
