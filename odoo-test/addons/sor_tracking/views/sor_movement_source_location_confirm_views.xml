<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sor_movement_source_location_confirm_form" model="ir.ui.view">
        <field name="name">sor.movement.source.location.confirm.form</field>
        <field name="model">sor.movement.source.location.confirm</field>
        <field name="arch" type="xml">
            <form string="Source Location Discrepancy">
                <sheet>
                    <div class="alert alert-warning mb-0" role="alert">
                        One or more products have a different recorded location than
                        the declared source. Review the details below before proceeding.
                    </div>
                    <group>
                        <field name="discrepancy_info" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" type="object"
                            string="Proceed" class="btn-primary"/>
                    <button name="action_cancel" type="object"
                            string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
