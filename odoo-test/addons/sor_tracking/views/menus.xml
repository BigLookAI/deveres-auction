<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         WINDOW ACTIONS
         ============================================================ -->

    <!-- Movement In — all incoming pickings regardless of sor_movement_state -->
    <record id="action_sor_movement_in" model="ir.actions.act_window">
        <field name="name">Movement In</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('picking_type_id.code', '=', 'incoming')]</field>
        <field name="context">{}</field>
    </record>

    <!-- Movement Out — all outgoing pickings regardless of sor_movement_state -->
    <record id="action_sor_movement_out" model="ir.actions.act_window">
        <field name="name">Movement Out</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('picking_type_id.code', '=', 'outgoing')]</field>
        <field name="context">{}</field>
    </record>

    <!-- Internal Transfers — all internal pickings regardless of sor_movement_state -->
    <record id="action_sor_movement_internal" model="ir.actions.act_window">
        <field name="name">Internal Transfers</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('picking_type_id.code', '=', 'internal')]</field>
        <field name="context">{}</field>
    </record>

    <!-- All Movements — root action; no domain filter so all pickings are reachable -->
    <record id="action_sor_movements_all" model="ir.actions.act_window">
        <field name="name">Movements</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
    </record>

    <!-- ============================================================
         LIST VIEW BINDINGS
         Bind the SOR list view to each window action.
         In Odoo 19, view_id on ir.actions.act_window is unreliable
         for list views; explicit binding records are required.
         ============================================================ -->

    <record id="action_sor_movements_all_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_picking_list_sor_tracking"/>
        <field name="act_window_id" ref="action_sor_movements_all"/>
    </record>

    <record id="action_sor_movement_in_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_picking_list_sor_tracking"/>
        <field name="act_window_id" ref="action_sor_movement_in"/>
    </record>

    <record id="action_sor_movement_out_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_picking_list_sor_tracking"/>
        <field name="act_window_id" ref="action_sor_movement_out"/>
    </record>

    <record id="action_sor_movement_internal_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_picking_list_sor_tracking"/>
        <field name="act_window_id" ref="action_sor_movement_internal"/>
    </record>

    <!-- ============================================================
         NAVIGATION MENUS
         ============================================================ -->

    <!-- Movements top-level navigation root -->
    <menuitem
        id="menu_sor_movements_root"
        name="Movements"
        action="action_sor_movements_all"
        sequence="20"
    />

    <!-- Dashboard sub-item — first in the sub-menu -->
    <menuitem
        id="menu_sor_tracking_dashboard"
        name="Dashboard"
        parent="menu_sor_movements_root"
        action="action_sor_tracking_dashboard"
        sequence="5"
    />

    <!-- Movement In sub-item -->
    <menuitem
        id="menu_sor_movement_in"
        name="Movement In"
        parent="menu_sor_movements_root"
        action="action_sor_movement_in"
        sequence="10"
    />

    <!-- Movement Out sub-item -->
    <menuitem
        id="menu_sor_movement_out"
        name="Movement Out"
        parent="menu_sor_movements_root"
        action="action_sor_movement_out"
        sequence="20"
    />

    <!-- Internal Transfers sub-item -->
    <menuitem
        id="menu_sor_movement_internal"
        name="Internal Transfers"
        parent="menu_sor_movements_root"
        action="action_sor_movement_internal"
        sequence="30"
    />



</odoo>
