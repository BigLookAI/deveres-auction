<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         DASHBOARD FORM VIEW
         TransientModel — each visit creates a fresh record so counts
         are always current.  @api.model action methods fire without
         requiring the record to be saved first.
         ============================================================ -->

    <record id="view_sor_tracking_dashboard_form" model="ir.ui.view">
        <field name="name">sor.tracking.dashboard.form</field>
        <field name="model">sor.tracking.dashboard</field>
        <field name="arch" type="xml">
            <form string="Movement Activity" create="0" edit="0" delete="0">
                <sheet>
                    <field name="name" invisible="1"/>

                    <!-- oe_button_box placed directly under sheet (not inside a group)
                         so the statinfo widget gets the expected CSS flex context.
                         Nesting inside group breaks the number/label two-line layout. -->
                    <separator string="Movement In"
                               invisible="mvi_queued == 0 and mvi_confirmed == 0 and mvi_cancelled == 0"/>
                    <div class="oe_button_box"
                         invisible="mvi_queued == 0 and mvi_confirmed == 0 and mvi_cancelled == 0">
                        <button class="oe_stat_button" type="object"
                                name="action_view_mvi_queued" icon="fa-clock-o"
                                invisible="mvi_queued == 0">
                            <field name="mvi_queued" widget="statinfo" string="Queued"/>
                        </button>
                        <button class="oe_stat_button" type="object"
                                name="action_view_mvi_confirmed" icon="fa-check-circle"
                                invisible="mvi_confirmed == 0">
                            <field name="mvi_confirmed" widget="statinfo" string="Received"/>
                        </button>
                        <button class="oe_stat_button" type="object"
                                name="action_view_mvi_cancelled" icon="fa-times-circle-o"
                                invisible="mvi_cancelled == 0">
                            <field name="mvi_cancelled" widget="statinfo" string="Cancelled"/>
                        </button>
                    </div>

                    <separator string="Movement Out"
                               invisible="mvo_queued == 0 and mvo_confirmed == 0 and mvo_cancelled == 0"/>
                    <div class="oe_button_box"
                         invisible="mvo_queued == 0 and mvo_confirmed == 0 and mvo_cancelled == 0">
                        <button class="oe_stat_button" type="object"
                                name="action_view_mvo_queued" icon="fa-clock-o"
                                invisible="mvo_queued == 0">
                            <field name="mvo_queued" widget="statinfo" string="Queued"/>
                        </button>
                        <button class="oe_stat_button" type="object"
                                name="action_view_mvo_confirmed" icon="fa-check-circle"
                                invisible="mvo_confirmed == 0">
                            <field name="mvo_confirmed" widget="statinfo" string="Dispatched"/>
                        </button>
                        <button class="oe_stat_button" type="object"
                                name="action_view_mvo_cancelled" icon="fa-times-circle-o"
                                invisible="mvo_cancelled == 0">
                            <field name="mvo_cancelled" widget="statinfo" string="Cancelled"/>
                        </button>
                    </div>

                    <separator string="Internal Transfers"
                               invisible="mvt_queued == 0"/>
                    <div class="oe_button_box"
                         invisible="mvt_queued == 0">
                        <button class="oe_stat_button" type="object"
                                name="action_view_mvt_queued" icon="fa-exchange"
                                invisible="mvt_queued == 0">
                            <field name="mvt_queued" widget="statinfo" string="Queued"/>
                        </button>
                    </div>

                    <!-- Named injection points for Level 1 agreement bridges.
                         sor_tracking_dashboard_external: agreement-aware counts
                         sor_tracking_dashboard_agreement_alerts: stale agreement alerts -->
                    <div name="sor_tracking_dashboard_external"/>
                    <div name="sor_tracking_dashboard_agreement_alerts"/>

                </sheet>
            </form>
        </field>
    </record>

    <!-- Window action — opens a new dashboard record on every visit so
         counts reflect the current state at load time -->
    <record id="action_sor_tracking_dashboard" model="ir.actions.act_window">
        <field name="name">Movement Activity</field>
        <field name="res_model">sor.tracking.dashboard</field>
        <field name="view_mode">form</field>
        <field name="context">{'form_view_initial_mode': 'readonly'}</field>
    </record>

</odoo>
