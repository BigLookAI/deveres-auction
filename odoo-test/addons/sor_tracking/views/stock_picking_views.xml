<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         LIST VIEW
         mode="primary" creates a standalone view so SOR window actions
         get their own list without affecting the native Inventory list.
         ============================================================ -->

    <record id="view_picking_list_sor_tracking" model="ir.ui.view">
        <field name="name">stock.picking.list.sor_tracking</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <!-- Row-level colour coding derived from stored movement state -->
            <xpath expr="//list" position="attributes">
                <attribute name="decoration-warning">sor_movement_state == 'ready'</attribute>
                <attribute name="decoration-success">sor_movement_state == 'confirmed'</attribute>
                <attribute name="decoration-muted">sor_movement_state == 'cancelled'</attribute>
            </xpath>
            <!-- Suppress Unreserve and Check Availability bulk action buttons —
                 SOR movements use the Confirm / Validate workflow, not the native
                 reserve/unreserve pattern. -->
            <xpath expr="//list/header/button[@name='do_unreserve']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//list/header/button[@name='action_assign']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <!-- Declare sor_movement_state before name so decoration-* can reference it;
                 column is hidden — field data is sent to the client but not rendered -->
            <xpath expr="//field[@name='name']" position="before">
                <field name="sor_movement_state" column_invisible="1"/>
            </xpath>
            <!-- Make partner_id default-visible (base list has optional="show") -->
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="optional"/>
            </xpath>
            <!-- Make scheduled_date default-visible (base list has optional="show") -->
            <xpath expr="//field[@name='scheduled_date']" position="attributes">
                <attribute name="optional"/>
            </xpath>
            <!-- Direction-aware state label column — shows Received / Dispatched /
                 Transferred / Queued / Cancelled instead of the raw selection value -->
            <xpath expr="//field[@name='scheduled_date']" position="after">
                <field name="sor_movement_state_label" string="Status"/>
            </xpath>
            <!-- Beneficial Owner column — optional so staff can hide it when not relevant -->
            <xpath expr="//field[@name='sor_movement_state_label']" position="after">
                <field name="owner_id" string="Beneficial Owner" optional="show"
                       readonly="sor_movement_state != 'queued'"/>
            </xpath>
            <!-- Operation Type column — change native optional="hide" to optional="show"
                 so it is visible by default without adding a duplicate column -->
            <xpath expr="//field[@name='picking_type_id'][@optional]" position="attributes">
                <attribute name="optional">show</attribute>
            </xpath>
            <!-- Suppress native state badge column — SOR uses sor_movement_state_label instead -->
            <xpath expr="//field[@name='state'][@widget='badge']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <!-- Suppress native columns not relevant to SOR movement lists -->
            <xpath expr="//field[@name='origin']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='company_id'][@groups='base.group_multi_company']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='priority']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='location_id'][@groups='stock.group_stock_multi_locations']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='location_dest_id'][@groups='stock.group_stock_multi_locations']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <!-- Suppress backorder_id from the optional column picker — irrelevant for unique objects -->
            <xpath expr="//field[@name='backorder_id']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <!-- ============================================================
         SEARCH VIEW
         Extends the native picking search to add sor_movement_state
         filters (Queued / Confirmed / Cancelled) after the native
         draft/waiting/ready state filters.
         The three native state filters (Draft / Waiting / Ready) are
         hidden — they reference Odoo's internal state machine which
         is not meaningful in the SOR movement context.
         ============================================================ -->

    <record id="view_picking_search_sor_tracking" model="ir.ui.view">
        <field name="name">stock.picking.search.sor_tracking</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_internal_search"/>
        <field name="arch" type="xml">
            <!-- Suppress native state filters not meaningful in SOR context -->
            <xpath expr="//filter[@name='draft']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//filter[@name='waiting']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//filter[@name='available']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <!-- Add SOR movement state filters after the (now hidden) available filter -->
            <xpath expr="//filter[@name='available']" position="after">
                <separator/>
                <filter name="sor_queued"
                        string="Queued"
                        domain="[('sor_movement_state', '=', 'queued')]"/>
                <filter name="sor_ready"
                        string="Ready"
                        domain="[('sor_movement_state', '=', 'ready')]"/>
                <filter name="sor_confirmed"
                        string="Confirmed"
                        domain="[('sor_movement_state', '=', 'confirmed')]"/>
                <filter name="sor_cancelled"
                        string="Cancelled"
                        domain="[('sor_movement_state', '=', 'cancelled')]"/>
                <separator/>
                <filter name="filter_receipts"
                        string="Receipts"
                        domain="[('picking_type_id.code', '=', 'incoming')]"/>
                <filter name="filter_deliveries"
                        string="Deliveries"
                        domain="[('picking_type_id.code', '=', 'outgoing')]"/>
                <filter name="filter_internal"
                        string="Internal Transfers"
                        domain="[('picking_type_id.code', '=', 'internal')]"/>
            </xpath>
        </field>
    </record>

    <!-- ============================================================
         FORM VIEW
         ============================================================ -->

    <record id="view_picking_form_sor_tracking" model="ir.ui.view">
        <field name="name">stock.picking.form.sor_tracking</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">

            <!-- Hide both native state statusbars — SOR replaces them with
                 sor_movement_state. Two variants exist in the native form:
                 one for incoming (draft/assigned/done) and one for all others
                 (draft/confirmed/assigned/done). Both are hidden. -->
            <xpath expr="//header/field[@name='state'][@statusbar_visible='draft,assigned,done']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//header/field[@name='state'][@statusbar_visible='draft,confirmed,assigned,done']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Rename both Validate buttons to Confirm — the highlighted variant
                 (shown when picking is assigned/ready) and the standard variant
                 (shown when picking is in draft/confirmed state). -->
            <xpath expr="//header/button[@name='button_validate'][hasclass('oe_highlight')]" position="attributes">
                <attribute name="string">Confirm</attribute>
            </xpath>
            <xpath expr="//header/button[@name='button_validate'][hasclass('o_btn_validate')]" position="attributes">
                <attribute name="string">Confirm</attribute>
            </xpath>

            <!-- Suppress Check Availability in the form header. Calling action_assign()
                 on an already-assigned picking creates an orphan demand line; the
                 BUG-08 guard in stock.move.line.create() then leaves it without a serial,
                 blocking button_validate. The list header button is already suppressed. -->
            <xpath expr="//header/button[@name='action_assign']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- SOR movement state statusbar. Direction-aware label is in the list view only —
                 the form badge (Queued/Confirmed/Cancelled) is sufficient here. -->
            <xpath expr="//header/button[@name='action_cancel']" position="before">
                <field name="sor_movement_state"
                       widget="statusbar"
                       statusbar_visible="queued,ready,confirmed,cancelled"
                       readonly="1"/>
            </xpath>

            <!-- Contextual hint box + arch declaration for sor_movement_hint.
                 The invisible field declaration ensures the arch parser can
                 resolve sor_movement_hint before evaluating the expression
                 on the outer div. The div itself shows the direction-specific
                 instruction text when the movement is queued. -->
            <xpath expr="//sheet/group[1]" position="before">
                <field name="sor_movement_hint" invisible="1"/>
                <div class="alert alert-info mb-3"
                     role="alert"
                     invisible="sor_movement_hint == ''">
                    <field name="sor_movement_hint" nolabel="1" readonly="1"/>
                </div>
            </xpath>

            <!-- Named injection point for Level 1 agreement bridges.
                 Renders as nothing with no bridge installed; bridge modules
                 inject agreement_id into this group via XPath. -->
            <xpath expr="//sheet/group[1]" position="after">
                <group name="sor_tracking_agreement_info"/>
            </xpath>

            <!-- Beneficial Owner — override the native owner_id field that is
                 restricted to incoming only and gated by group_tracking_owner.
                 SOR shows it for MVI, MVO, and Internal Transfers (e.g. Artist
                 Studio → Gallery moves preserve the artwork's beneficial owner). -->
            <xpath expr="//field[@name='owner_id']" position="attributes">
                <attribute name="groups"/>
                <attribute name="string">Beneficial Owner</attribute>
                <attribute name="help">Only required when the legal owner of the goods differs from the Contact above — for example, a dealer acting on behalf of a collector. Leave blank when the contact and owner are the same person.</attribute>
                <attribute name="invisible">picking_type_code not in ('incoming', 'outgoing', 'internal')</attribute>
                <attribute name="readonly">sor_movement_state != 'queued'</attribute>
            </xpath>

            <!-- Restrict location dropdowns to gallery-relevant locations only.
                 Shows Viewing Locations/Rooms/Studios (internal usage),
                 contact-linked external locations (customer usage), and
                 Partner/External pool (supplier usage). Excludes generic Odoo
                 virtual locations (Customers, Vendors, etc.) which all have
                 company_id=False. Odoo's ir.rule on stock.location already
                 handles per-company isolation — this domain only needs to
                 strip the global virtual locations.
                 Target the multi-locations group variant — the base form has
                 two location_id fields; the visible one carries groups=stock.group_stock_multi_locations. -->
            <xpath expr="//field[@name='location_id'][@groups='stock.group_stock_multi_locations']" position="attributes">
                <attribute name="domain">[('usage', 'in', ['internal', 'customer', 'supplier']), ('company_id', '!=', False)]</attribute>
            </xpath>
            <xpath expr="//field[@name='location_dest_id'][@groups='stock.group_stock_multi_locations']" position="attributes">
                <attribute name="domain">[('usage', 'in', ['internal', 'customer', 'supplier']), ('company_id', '!=', False)]</attribute>
            </xpath>

            <!-- Always show source location — override native incoming-hides-source rule -->
            <xpath expr="//field[@name='location_id'][@groups='stock.group_stock_multi_locations']" position="attributes">
                <attribute name="invisible">False</attribute>
            </xpath>

            <!-- Always show destination location — override native outgoing-hides-destination rule -->
            <xpath expr="//field[@name='location_dest_id'][@groups='stock.group_stock_multi_locations']" position="attributes">
                <attribute name="invisible">False</attribute>
            </xpath>

            <!-- Suppress description_picking column in Operations tab move list.
                 Odoo populates this from product Internal Notes; it is noise in
                 the movement operational context. optional="show" makes it
                 visible by default — override with column_invisible to hide it. -->
            <xpath expr="//field[@name='move_ids']//field[@name='description_picking']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>

            <!-- Operation type is inferred — always read-only on SOR movement forms.
                 The native field is editable until done/cancel; we override to lock it
                 unconditionally so staff cannot override the inference. -->
            <xpath expr="//field[@name='picking_type_id'][@domain]" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

        </field>
    </record>

</odoo>
