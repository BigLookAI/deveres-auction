<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!--
            SOR Tracking demo movements — DESIGN REFERENCE ONLY.

            NOTE: This file is NOT listed in the manifest 'demo' key and will NOT load
            automatically. In Odoo 19, the safe_eval context for data/demo XML only
            includes {'lang': ...} — 'env' is not defined, so eval="env[...]" expressions
            raise NameError at load time.

            Demo movements are instead created via the reset scripts
            (tools/demo/reset_*.sh) using the Python ORM approach after install,
            consistent with the artwork location assignment pattern.

            This file serves as documentation of the intended demo data structure.
        -->

        <!-- ===== Movement In (incoming) ===== -->

        <!-- Queued receipt: demo artworks arriving at Main Gallery from a collector -->
        <record id="demo_picking_in_01" model="stock.picking">
            <field name="picking_type_id" eval="env['stock.picking.type'].search([('code','=','incoming'),('warehouse_id.code','=','MAIN')], limit=1).id"/>
            <field name="location_id" eval="env['stock.location'].search([('name','=','Partners/External'),('company_id','=',env.company.id)], limit=1).id"/>
            <field name="location_dest_id" eval="env['stock.warehouse'].search([('code','=','MAIN')], limit=1).lot_stock_id.id"/>
            <field name="partner_id" ref="sor_contact_roles.demo_collector_john"/>
            <field name="sor_movement_state">queued</field>
        </record>
        <record id="demo_move_in_01_a" model="stock.move">
            <field name="picking_id" ref="demo_picking_in_01"/>
            <field name="product_id" eval="env.ref('sor_artwork.demo_artwork_01').product_variant_ids[0].id"/>
            <field name="product_uom_qty">1.0</field>
            <field name="product_uom" ref="uom.product_uom_unit"/>
            <field name="location_id" eval="env['stock.location'].search([('name','=','Partners/External'),('company_id','=',env.company.id)], limit=1).id"/>
            <field name="location_dest_id" eval="env['stock.warehouse'].search([('code','=','MAIN')], limit=1).lot_stock_id.id"/>
        </record>
        <record id="demo_move_in_01_b" model="stock.move">
            <field name="picking_id" ref="demo_picking_in_01"/>
            <field name="product_id" eval="env.ref('sor_artwork.demo_artwork_02').product_variant_ids[0].id"/>
            <field name="product_uom_qty">1.0</field>
            <field name="product_uom" ref="uom.product_uom_unit"/>
            <field name="location_id" eval="env['stock.location'].search([('name','=','Partners/External'),('company_id','=',env.company.id)], limit=1).id"/>
            <field name="location_dest_id" eval="env['stock.warehouse'].search([('code','=','MAIN')], limit=1).lot_stock_id.id"/>
        </record>

        <!-- Queued receipt: demo artwork arriving at Secondary Space from a dealer -->
        <record id="demo_picking_in_02" model="stock.picking">
            <field name="picking_type_id" eval="env['stock.picking.type'].search([('code','=','incoming'),('warehouse_id.code','=','SEC')], limit=1).id"/>
            <field name="location_id" eval="env['stock.location'].search([('name','=','Partners/External'),('company_id','=',env.company.id)], limit=1).id"/>
            <field name="location_dest_id" eval="env['stock.warehouse'].search([('code','=','SEC')], limit=1).lot_stock_id.id"/>
            <field name="partner_id" ref="sor_contact_roles.demo_dealer_william"/>
            <field name="sor_movement_state">queued</field>
        </record>
        <record id="demo_move_in_02_a" model="stock.move">
            <field name="picking_id" ref="demo_picking_in_02"/>
            <field name="product_id" eval="env.ref('sor_artwork.demo_artwork_06').product_variant_ids[0].id"/>
            <field name="product_uom_qty">1.0</field>
            <field name="product_uom" ref="uom.product_uom_unit"/>
            <field name="location_id" eval="env['stock.location'].search([('name','=','Partners/External'),('company_id','=',env.company.id)], limit=1).id"/>
            <field name="location_dest_id" eval="env['stock.warehouse'].search([('code','=','SEC')], limit=1).lot_stock_id.id"/>
        </record>

        <!-- Confirmed (Received): artwork received into Collection Storage -->
        <record id="demo_picking_in_03" model="stock.picking">
            <field name="picking_type_id" eval="env['stock.picking.type'].search([('code','=','incoming'),('warehouse_id.code','=','STOR')], limit=1).id"/>
            <field name="location_id" eval="env['stock.location'].search([('name','=','Partners/External'),('company_id','=',env.company.id)], limit=1).id"/>
            <field name="location_dest_id" eval="env['stock.warehouse'].search([('code','=','STOR')], limit=1).lot_stock_id.id"/>
            <field name="partner_id" ref="sor_contact_roles.demo_institution_national_gallery"/>
            <field name="sor_movement_state">confirmed</field>
        </record>
        <record id="demo_move_in_03_a" model="stock.move">
            <field name="picking_id" ref="demo_picking_in_03"/>
            <field name="product_id" eval="env.ref('sor_artwork.demo_artwork_11').product_variant_ids[0].id"/>
            <field name="product_uom_qty">1.0</field>
            <field name="product_uom" ref="uom.product_uom_unit"/>
            <field name="location_id" eval="env['stock.location'].search([('name','=','Partners/External'),('company_id','=',env.company.id)], limit=1).id"/>
            <field name="location_dest_id" eval="env['stock.warehouse'].search([('code','=','STOR')], limit=1).lot_stock_id.id"/>
        </record>

        <!-- ===== Movement Out (outgoing) ===== -->

        <!-- Queued dispatch: artwork leaving Main Gallery to a collector -->
        <record id="demo_picking_out_01" model="stock.picking">
            <field name="picking_type_id" eval="env['stock.picking.type'].search([('code','=','outgoing'),('warehouse_id.code','=','MAIN')], limit=1).id"/>
            <field name="location_id" eval="env['stock.warehouse'].search([('code','=','MAIN')], limit=1).lot_stock_id.id"/>
            <field name="location_dest_id" eval="env['stock.location'].search([('name','=','Buyers/External'),('company_id','=',env.company.id)], limit=1).id"/>
            <field name="partner_id" ref="sor_contact_roles.demo_collector_bridget"/>
            <field name="sor_movement_state">queued</field>
        </record>
        <record id="demo_move_out_01_a" model="stock.move">
            <field name="picking_id" ref="demo_picking_out_01"/>
            <field name="product_id" eval="env.ref('sor_artwork.demo_artwork_04').product_variant_ids[0].id"/>
            <field name="product_uom_qty">1.0</field>
            <field name="product_uom" ref="uom.product_uom_unit"/>
            <field name="location_id" eval="env['stock.warehouse'].search([('code','=','MAIN')], limit=1).lot_stock_id.id"/>
            <field name="location_dest_id" eval="env['stock.location'].search([('name','=','Buyers/External'),('company_id','=',env.company.id)], limit=1).id"/>
        </record>

        <!-- Queued dispatch: artwork leaving Secondary Space to an institution -->
        <record id="demo_picking_out_02" model="stock.picking">
            <field name="picking_type_id" eval="env['stock.picking.type'].search([('code','=','outgoing'),('warehouse_id.code','=','SEC')], limit=1).id"/>
            <field name="location_id" eval="env['stock.warehouse'].search([('code','=','SEC')], limit=1).lot_stock_id.id"/>
            <field name="location_dest_id" eval="env['stock.location'].search([('name','=','Buyers/External'),('company_id','=',env.company.id)], limit=1).id"/>
            <field name="partner_id" ref="sor_contact_roles.demo_institution_rha"/>
            <field name="sor_movement_state">queued</field>
        </record>
        <record id="demo_move_out_02_a" model="stock.move">
            <field name="picking_id" ref="demo_picking_out_02"/>
            <field name="product_id" eval="env.ref('sor_artwork.demo_artwork_08').product_variant_ids[0].id"/>
            <field name="product_uom_qty">1.0</field>
            <field name="product_uom" ref="uom.product_uom_unit"/>
            <field name="location_id" eval="env['stock.warehouse'].search([('code','=','SEC')], limit=1).lot_stock_id.id"/>
            <field name="location_dest_id" eval="env['stock.location'].search([('name','=','Buyers/External'),('company_id','=',env.company.id)], limit=1).id"/>
        </record>

        <!-- ===== Internal Transfer ===== -->

        <!-- Queued transfer: artwork moving from Main Gallery to Secondary Space -->
        <record id="demo_picking_int_01" model="stock.picking">
            <field name="picking_type_id" eval="env['stock.picking.type'].search([('code','=','internal'),('warehouse_id.code','=','MAIN'),('name','ilike','Internal')], limit=1).id"/>
            <field name="location_id" eval="env['stock.warehouse'].search([('code','=','MAIN')], limit=1).lot_stock_id.id"/>
            <field name="location_dest_id" eval="env['stock.warehouse'].search([('code','=','SEC')], limit=1).lot_stock_id.id"/>
            <field name="sor_movement_state">queued</field>
        </record>
        <record id="demo_move_int_01_a" model="stock.move">
            <field name="picking_id" ref="demo_picking_int_01"/>
            <field name="product_id" eval="env.ref('sor_artwork.demo_artwork_03').product_variant_ids[0].id"/>
            <field name="product_uom_qty">1.0</field>
            <field name="product_uom" ref="uom.product_uom_unit"/>
            <field name="location_id" eval="env['stock.warehouse'].search([('code','=','MAIN')], limit=1).lot_stock_id.id"/>
            <field name="location_dest_id" eval="env['stock.warehouse'].search([('code','=','SEC')], limit=1).lot_stock_id.id"/>
        </record>
    </data>
</odoo>
