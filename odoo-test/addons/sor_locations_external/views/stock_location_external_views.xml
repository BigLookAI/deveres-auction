<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view: External Locations with contact and address summary. -->
    <record id="view_external_location_list" model="ir.ui.view">
        <field name="name">sor.external.location.list</field>
        <field name="model">stock.location</field>
        <field name="arch" type="xml">
            <list string="External Locations">
                <field name="name" string="External Location"/>
                <field name="contact_id" string="Customer Contact"/>
                <field name="ext_city" string="City"/>
                <field name="ext_country_id" string="Country"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- Search view: search by name or contact; filter and group by contact. -->
    <record id="view_external_location_search" model="ir.ui.view">
        <field name="name">sor.external.location.search</field>
        <field name="model">stock.location</field>
        <field name="arch" type="xml">
            <search string="External Locations">
                <field name="name" string="Location Name"/>
                <field name="contact_id" string="Customer Contact"/>
                <filter string="External Locations"
                        name="filter_external_locations"
                        domain="[('usage', '=', 'customer'), ('contact_id', '!=', False)]"/>
                <separator/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group>
                    <filter string="Customer Contact" name="group_by_contact"
                            domain="[]" context="{'group_by': 'contact_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Form view (primary): External Location fields layered on the standard location form.
         mode=primary keeps this separate from the standard Locations form and the Rooms form.
         Inherits stock.view_location_form and adds contact linkage + address section.

         The stock form structure used here:
           <sheet>
             <div name="button_box"/>
             <h1><field name="name"/></h1>
             <h2><field name="location_id"/></h2>
             <group>
               <group name="additional_info">...</group>
             </group>
           </sheet>
    -->
    <record id="view_external_location_form" model="ir.ui.view">
        <field name="name">sor.external.location.form</field>
        <field name="model">stock.location</field>
        <field name="inherit_id" ref="stock.view_location_form"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <!-- Relabel location_id and restrict to External Locations parent only.
                 Readonly on existing records (readonly="id"); on new records default_get
                 pre-populates it with the External Locations view location and the domain
                 restricts the dropdown to view-type locations named "External Locations". -->
            <xpath expr="//h2/field[@name='location_id']" position="attributes">
                <attribute name="string">External Locations</attribute>
                <attribute name="domain">[('usage', '=', 'view'), ('name', '=', 'External Locations')]</attribute>
                <attribute name="readonly">id</attribute>
            </xpath>
            <!-- Insert contact_id as the first field in the Additional Information group.
                 Make usage (Location Type) readonly — External locations are always Customer. -->
            <xpath expr="//group[@name='additional_info']/field[@name='usage']" position="before">
                <field name="contact_id"/>
            </xpath>
            <xpath expr="//group[@name='additional_info']/field[@name='usage']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
            <!-- Add External Address section after the main group block. -->
            <xpath expr="//sheet/group" position="after">
                <group string="External Address">
                    <group>
                        <field name="ext_street" placeholder="Street"/>
                        <field name="ext_city" placeholder="City"/>
                    </group>
                    <group>
                        <field name="ext_zip" placeholder="ZIP / Postcode"/>
                        <field name="ext_country_id"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Override the base External Locations action to use the bridge's richer views
         and add sor_external_context so default_get populates location_id correctly. -->
    <record id="sor_locations.action_external_location_form" model="ir.actions.act_window">
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_external_location_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_external_location_form')}),
        ]"/>
        <field name="search_view_id" ref="view_external_location_search"/>
        <field name="context">{'default_usage': 'customer', 'sor_external_context': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first External Location
            </p>
            <p>
                External locations represent where artworks are held outside the gallery:
                at a buyer, borrower, institution, or in transit.
                Enable "External Locations" in Inventory → Configuration → Settings first,
                then create locations here or directly from a customer contact record.
            </p>
        </field>
    </record>

</odoo>
