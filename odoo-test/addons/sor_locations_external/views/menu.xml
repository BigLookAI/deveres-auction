<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- External Locations menu: sequence=14, after Rooms (12) and Artist Studios (13).
         Starts inactive — activated by set_values() when "External Locations" is enabled
         in Inventory → Configuration → Settings. Deactivated when disabled.
         Requires Storage Locations group (enabled by sor_locations post_init_hook). -->
    <menuitem
        id="menu_external_locations"
        name="External Locations"
        parent="stock.menu_warehouse_config"
        action="sor_locations.action_external_location_form"
        sequence="14"
        groups="stock.group_stock_multi_locations"
        active="False"/>

</odoo>
