<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         T2: Add current_location_id to the artwork form view.
         Inherits sor_artwork's artwork form (which itself inherits from
         product.product_template_form_view) and adds the field after
         creation_year in the General Information tab.
         ================================================================ -->
    <record id="view_product_template_form_inherit_location" model="ir.ui.view">
        <field name="name">product.template.form.inherit.sor_locations_artwork</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="sor_artwork.view_product_template_form_artwork"/>
        <field name="arch" type="xml">
            <!-- Add Current Location after creation_year.
                 creation_year is only shown for artwork products; current_location_id
                 is always accessible (field is on all product.template records)
                 but is most meaningful for artworks. -->
            <xpath expr="//field[@name='creation_year']" position="after">
                <field name="current_location_id"
                       string="Current Location"
                       options="{'no_create': True, 'no_open': False}"/>
            </xpath>
        </field>
    </record>

    <!-- ================================================================
         T3: Artwork Locations Dashboard.

         List view: shows artworks with their current location as the
         primary column. Inherits the sor_artwork list view (mode=primary
         so this is a standalone view used only by the dashboard action).
         ================================================================ -->
    <record id="view_artwork_location_dashboard_list" model="ir.ui.view">
        <field name="name">product.template.list.artwork.locations</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="sor_artwork.view_product_template_tree_artwork"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <list position="attributes">
                <attribute name="string">Artwork Locations</attribute>
            </list>
            <!-- Insert current_location_id as the first column after name -->
            <field name="name" position="after">
                <field name="current_location_id" string="Current Location" optional="show"/>
            </field>
        </field>
    </record>

    <!-- Search view for the dashboard: inherits the sor_artwork search view
         (mode=primary — scoped to the dashboard action only) and adds
         location-specific search, filter, and group-by options. -->
    <record id="view_artwork_location_dashboard_search" model="ir.ui.view">
        <field name="name">product.template.search.artwork.locations</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="sor_artwork.view_product_template_search_artwork"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <!-- Add current_location_id as a searchable field -->
            <field name="creator_id" position="after">
                <field name="current_location_id" string="Current Location"/>
            </field>
            <!-- Add location filters after the certificate filters -->
            <filter name="filter_without_certificate" position="after">
                <separator/>
                <filter string="At a Location" name="filter_has_location"
                        domain="[('current_location_id', '!=', False)]"/>
                <filter string="No Location Assigned" name="filter_no_location"
                        domain="[('current_location_id', '=', False)]"/>
            </filter>
            <!-- Add Location group-by option -->
            <group position="inside">
                <filter string="Location" name="group_by_location"
                        domain="[]" context="{'group_by': 'current_location_id'}"/>
            </group>
        </field>
    </record>

    <!-- Window action for the Artwork Locations Dashboard.
         Domain: artwork products only.
         Default group-by: current_location_id (so opening the dashboard
         immediately shows artworks grouped by their current location). -->
    <record id="action_artwork_location_dashboard" model="ir.actions.act_window">
        <field name="name">Artwork Locations</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('product_type', '=', 'artwork')]</field>
        <field name="context">{'search_default_group_by_location': 1}</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_artwork_location_dashboard_list')}),
        ]"/>
        <field name="search_view_id" ref="view_artwork_location_dashboard_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No artworks found
            </p>
            <p>
                Artworks appear here once created. Open any artwork and set its
                Current Location to track where it is physically held.
            </p>
        </field>
    </record>

</odoo>
