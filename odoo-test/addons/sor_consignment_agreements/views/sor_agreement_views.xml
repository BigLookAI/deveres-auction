<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Custom minimal picking list for the "Link Existing Intake/Release" dialog.
         create="0" suppresses the "New" button; no editable mode avoids Save/Discard noise.
         "Link to Agreement" button per row writes agreement_id via action_link_to_agreement. -->
    <record id="view_picking_link_dialog_list" model="ir.ui.view">
        <field name="name">stock.picking.link.dialog.list</field>
        <field name="model">stock.picking</field>
        <field name="arch" type="xml">
            <list string="Select Movement" create="0" delete="0">
                <field name="name" string="Reference"/>
                <field name="partner_id" string="Partner"/>
                <field name="scheduled_date" string="Scheduled Date"/>
                <field name="state" string="Status" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-warning="state in ('waiting', 'confirmed')"
                       decoration-info="state == 'draft'"
                       decoration-danger="state == 'cancel'"/>
                <button name="action_link_to_agreement"
                        type="object"
                        string="Link to Agreement"
                        class="btn btn-primary btn-sm"/>
            </list>
        </field>
    </record>

    <record id="view_sor_agreement_form_consignment" model="ir.ui.view">
        <field name="name">sor.agreement.form.consignment</field>
        <field name="model">sor.agreement</field>
        <field name="inherit_id" ref="sor_legal_agreement.view_sor_agreement_form"/>
        <field name="arch" type="xml">

            <!-- Action buttons — visible in Draft state only per agreement type (BUG-04, BUG-10) -->
            <xpath expr="//header" position="inside">
                <button name="action_create_intake"
                        type="object"
                        string="Create Intake"
                        class="btn-primary"
                        invisible="agreement_type != 'consignment_in' or state != 'draft'"/>
                <button name="action_link_existing_intake"
                        type="object"
                        string="Link Existing Intake"
                        invisible="agreement_type != 'consignment_in' or state != 'draft'"/>
                <button name="action_create_release"
                        type="object"
                        string="Create Release"
                        class="btn-primary"
                        invisible="agreement_type != 'consignment_out' or state != 'draft'"/>
                <button name="action_link_existing_release"
                        type="object"
                        string="Link Existing Release"
                        invisible="agreement_type != 'consignment_out' or state != 'draft'"/>
            </xpath>

            <!-- Compound status — displayed below statusbar on Active Consignment In agreements -->
            <xpath expr="//field[@name='state']" position="after">
                <field name="sor_compound_status"
                       readonly="1"
                       nolabel="1"
                       class="text-muted"
                       invisible="not sor_compound_status"/>
            </xpath>

            <!-- Statusbar: extend visible states for consignment lifecycle -->
            <xpath expr="//field[@name='state'][@widget='statusbar']" position="attributes">
                <attribute name="statusbar_visible">draft,pending_signature,active,partial_return,returned,sold,closed</attribute>
            </xpath>

            <!-- Declare move_ids in arch so the FormArchParser can resolve its type -->
            <xpath expr="//notebook" position="before">
                <field name="move_ids" invisible="1"/>
            </xpath>

            <!-- Source Consignment field — visible only on Consignment Out type -->
            <xpath expr="//field[@name='primary_partner_id']" position="after">
                <field name="source_consignment_id"
                       invisible="agreement_type != 'consignment_out'"
                       readonly="state != 'draft'"/>
            </xpath>

            <!-- Hide base Lines tab for consignment types -->
            <xpath expr="//page[@name='lines']" position="attributes">
                <attribute name="invisible">agreement_type in ('consignment_in', 'consignment_out')</attribute>
            </xpath>

            <!-- Hide base Internal tab for consignment types — Movements tab covers this (BUG-06) -->
            <xpath expr="//page[@name='internal']" position="attributes">
                <attribute name="invisible">agreement_type in ('consignment_in', 'consignment_out')</attribute>
            </xpath>

            <!-- Movements tab — visible only for consignment agreement types -->
            <xpath expr="//page[@name='lines']" position="after">
                <page name="sor_movements"
                      string="Movements"
                      invisible="agreement_type not in ('consignment_in', 'consignment_out')">

                    <!-- Section 1 — Linked pickings -->
                    <separator string="Linked Movements"/>
                    <field name="picking_ids" nolabel="1" options="{'create': False}">
                        <list>
                            <field name="name" string="Reference"/>
                            <field name="picking_type_id" string="Operation Type"/>
                            <field name="scheduled_date" string="Scheduled Date"/>
                            <field name="partner_id" string="Partner"/>
                            <field name="state" string="Status" widget="badge"
                                   decoration-success="state == 'done'"
                                   decoration-warning="state in ('waiting', 'confirmed')"
                                   decoration-info="state == 'draft'"
                                   decoration-danger="state == 'cancel'"/>
                            <button name="action_open_picking_modal"
                                    type="object"
                                    string="Open ↗"
                                    class="btn btn-link p-0"/>
                        </list>
                    </field>

                    <!-- Section 2 — Product lines (flat read-only view across all linked pickings) -->
                    <separator string="Product Lines"/>
                    <field name="move_ids" nolabel="1" readonly="1">
                        <list editable="bottom" create="0" delete="0">
                            <field name="picking_id" string="Movement"/>
                            <field name="product_id" string="Product"
                                   options="{'no_open': True}"/>
                            <field name="lot_ids" string="Serial Number"
                                   widget="many2many_tags" readonly="1"/>
                            <field name="product_qty" string="Quantity"/>
                            <field name="state" string="Status"/>
                            <button name="action_open_product_modal"
                                    type="object"
                                    string="Open ↗"
                                    class="btn btn-link p-0"/>
                        </list>
                    </field>

                </page>
            </xpath>

        </field>
    </record>

    <!-- Consignment In filtered window action -->
    <record id="action_sor_consignment_in" model="ir.actions.act_window">
        <field name="name">Consignment In</field>
        <field name="res_model">sor.agreement</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('agreement_type', '=', 'consignment_in')]</field>
        <field name="view_id" ref="sor_legal_agreement.view_sor_agreement_list"/>
        <field name="search_view_id" ref="sor_legal_agreement.view_sor_agreement_search"/>
    </record>

    <!-- Consignment Out filtered window action -->
    <record id="action_sor_consignment_out" model="ir.actions.act_window">
        <field name="name">Consignment Out</field>
        <field name="res_model">sor.agreement</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('agreement_type', '=', 'consignment_out')]</field>
        <field name="view_id" ref="sor_legal_agreement.view_sor_agreement_list"/>
        <field name="search_view_id" ref="sor_legal_agreement.view_sor_agreement_search"/>
    </record>

    <!-- Navigation sub-links under the Legal root menu (BUG-07).
         Additive bridge pattern: new entries created in sor_consignment_agreements
         namespace; sor_legal_agreement.menu_sor_root and menu_sor_agreements untouched. -->
    <menuitem id="menu_sor_consignment_in"
              name="Consignment In"
              parent="sor_legal_agreement.menu_sor_root"
              action="action_sor_consignment_in"
              sequence="20"/>

    <menuitem id="menu_sor_consignment_out"
              name="Consignment Out"
              parent="sor_legal_agreement.menu_sor_root"
              action="action_sor_consignment_out"
              sequence="30"/>

</odoo>
