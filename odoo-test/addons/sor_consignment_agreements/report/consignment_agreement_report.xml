<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_sor_agreement_consignment"
              inherit_id="sor_legal_agreement.report_sor_agreement">

        <!-- AC 1 — Relabel "Counterparty:" as "Consignor:" for Consignment In -->
        <xpath expr="//p[span[@t-field='doc.primary_partner_id']][not(ancestor::table)]/strong"
               position="replace">
            <t t-if="doc.agreement_type == 'consignment_in'">
                <strong>Consignor:</strong>
            </t>
            <t t-else="">
                <strong>Counterparty:</strong>
            </t>
        </xpath>

        <!-- AC 3 — Source consignment traceability (Consignment Out only) -->
        <xpath expr="//p[span[@t-field='doc.primary_partner_id']][not(ancestor::table)]"
               position="after">
            <t t-if="doc.agreement_type == 'consignment_out' and doc.source_consignment_id">
                <p>
                    <strong>Source Consignment:</strong>
                    <span t-field="doc.source_consignment_id.name"/>
                </p>
            </t>
        </xpath>

        <!-- BUG-09: Suppress base "Items" h3 heading for consignment types.
             The consignment section below inserts its own "Items" heading. -->
        <xpath expr="//h3[normalize-space()='Items']" position="replace">
            <h3 t-if="doc.agreement_type not in ['consignment_in', 'consignment_out']">Items</h3>
        </xpath>

        <!-- BUG-09: Suppress base Items table for consignment types.
             Targeted by the line_ids t-foreach on the tbody row — unique to the base Items table. -->
        <xpath expr="//table[.//tr[@t-foreach='doc.line_ids']]" position="attributes">
            <attribute name="t-if">doc.agreement_type not in ['consignment_in', 'consignment_out']</attribute>
        </xpath>

        <!-- AC 2, AC 4, BUG-09 Option A: Flat product lines from picking_ids.move_ids.
             line_ids is always empty on consignment agreements (no manual entry UI).
             Nested foreach: for each linked picking, one row per move.
             Columns: Movement reference | Product. No Qty/Serial. -->
        <xpath expr="//h3[normalize-space()='Terms and Conditions']"
               position="before">
            <t t-if="doc.agreement_type in ['consignment_in', 'consignment_out']">
                <h3>Items</h3>
                <t t-if="doc.picking_ids">
                    <table class="table table-sm" style="width:100%; table-layout:fixed; margin-bottom:12pt;">
                        <colgroup>
                            <col style="width:30%;"/>
                            <col style="width:70%;"/>
                        </colgroup>
                        <thead>
                            <tr>
                                <th>Movement</th>
                                <th>Product</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="doc.picking_ids" t-as="picking">
                                <t t-foreach="picking.move_ids" t-as="move">
                                    <tr>
                                        <td style="word-wrap:break-word; overflow-wrap:break-word;">
                                            <span t-esc="picking.name"/>
                                        </td>
                                        <td style="word-wrap:break-word; overflow-wrap:break-word;">
                                            <span t-field="move.product_id"/>
                                        </td>
                                    </tr>
                                </t>
                            </t>
                        </tbody>
                    </table>
                </t>
                <t t-else="">
                    <p style="color:#888; font-style:italic;">No product lines.</p>
                </t>
            </t>
        </xpath>

    </template>
</odoo>
