<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Demo consignment agreements with auction house terms for Story 04 UAT.
             Both are active consignment-in agreements — artwork consigned to the auction
             house by the vendor, with catalogue estimate, reserve price, and vendor
             commission set.

             Agreement 1: William Burke consigned "Seascape Morning" (lot 201)
             for Important Irish Art 2026 — active, signed and in force. -->
        <record id="demo_agreement_consignment_01" model="sor.agreement">
            <field name="name">AGR/DEMO/00001</field>
            <field name="agreement_type">consignment_in</field>
            <field name="primary_partner_id" ref="sor_contact_roles.demo_dealer_william"/>
            <field name="state">active</field>
            <field name="date_start" eval="(datetime.now() - timedelta(days=45)).strftime('%Y-%m-%d')"/>
            <field name="catalogue_estimate">6000.0</field>
            <field name="reserve_price">5000.0</field>
            <field name="vendor_commission_pct">15.0</field>
        </record>

        <!-- Agreement 2: Patricia Doyle consigned "Still Life with Books" (lot 202)
             for Important Irish Art 2026 — active. -->
        <record id="demo_agreement_consignment_02" model="sor.agreement">
            <field name="name">AGR/DEMO/00002</field>
            <field name="agreement_type">consignment_in</field>
            <field name="primary_partner_id" ref="sor_contact_roles.demo_dealer_patricia"/>
            <field name="state">active</field>
            <field name="date_start" eval="(datetime.now() - timedelta(days=40)).strftime('%Y-%m-%d')"/>
            <field name="catalogue_estimate">4000.0</field>
            <field name="reserve_price">3200.0</field>
            <field name="vendor_commission_pct">12.0</field>
        </record>

        <!-- Agreement 3: William Burke — a second consignment (Spring Sale 2024, lot 51)
             in closed state — demonstrates terminal state read-only behaviour. -->
        <record id="demo_agreement_consignment_03" model="sor.agreement">
            <field name="name">AGR/DEMO/00003</field>
            <field name="agreement_type">consignment_in</field>
            <field name="primary_partner_id" ref="sor_contact_roles.demo_dealer_william"/>
            <field name="state">closed</field>
            <field name="date_start" eval="(datetime.now() - timedelta(days=210)).strftime('%Y-%m-%d')"/>
            <field name="date_end" eval="(datetime.now() - timedelta(days=170)).strftime('%Y-%m-%d')"/>
            <field name="catalogue_estimate">3500.0</field>
            <field name="reserve_price">2800.0</field>
            <field name="vendor_commission_pct">15.0</field>
        </record>
    </data>
</odoo>
