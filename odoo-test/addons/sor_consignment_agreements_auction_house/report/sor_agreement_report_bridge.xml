<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend the consignment agreement PDF to add an "Auction Terms" section
         before the Terms and Conditions heading. Rows are only rendered when
         the field has a non-zero value (AC 9). vendor_commission_amount is
         omitted from the PDF at MVP (D2 scope: lot-linking not yet implemented). -->
    <template id="report_sor_agreement_auction_house_bridge"
              inherit_id="sor_consignment_agreements.report_sor_agreement_consignment">
        <xpath expr="//h3[normalize-space()='Terms and Conditions']"
               position="before">
            <t t-if="doc.agreement_type == 'consignment_in' and (
                doc.catalogue_estimate or doc.reserve_price or doc.vendor_commission_pct)">
                <h3>Auction Terms</h3>
                <table class="table table-sm" style="width:100%;">
                    <tbody>
                        <t t-if="doc.catalogue_estimate">
                            <tr>
                                <td style="width:50%;"><strong>Catalogue Estimate</strong></td>
                                <td>
                                    <span t-out="doc.catalogue_estimate"
                                          t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                </td>
                            </tr>
                        </t>
                        <t t-if="doc.reserve_price">
                            <tr>
                                <td><strong>Reserve Price</strong></td>
                                <td>
                                    <span t-out="doc.reserve_price"
                                          t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                </td>
                            </tr>
                        </t>
                        <t t-if="doc.vendor_commission_pct">
                            <tr>
                                <td><strong>Vendor Commission</strong></td>
                                <td>
                                    <span t-out="doc.vendor_commission_pct"/>%
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </t>
        </xpath>
    </template>
</odoo>
