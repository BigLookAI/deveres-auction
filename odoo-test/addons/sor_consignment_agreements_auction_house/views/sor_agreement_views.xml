<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add "Auction Terms" notebook page to the consignment agreement form.
         Only relevant for consignment_in agreements (lots are consigned in for auction).
         Fields are editable in draft, pending_signature, and active states;
         read-only in terminal states (revoked, closed). -->
    <record id="view_sor_agreement_form_auction_house" model="ir.ui.view">
        <field name="name">sor.agreement.view.form.auction.house</field>
        <field name="model">sor.agreement</field>
        <field name="inherit_id" ref="sor_legal_agreement.view_sor_agreement_form"/>
        <field name="arch" type="xml">
            <!-- Declare currency_id for Monetary widget resolution -->
            <xpath expr="//notebook" position="before">
                <field name="currency_id" invisible="1"/>
            </xpath>
            <!-- Append Auction Terms page at end of notebook -->
            <xpath expr="//notebook" position="inside">
                <page name="auction_terms" string="Auction Terms"
                      invisible="agreement_type != 'consignment_in'">
                    <group>
                        <group string="Estimates &amp; Reserve">
                            <field name="catalogue_estimate"
                                   readonly="state in ('revoked', 'closed')"/>
                            <field name="reserve_price"
                                   readonly="state in ('revoked', 'closed')"/>
                        </group>
                        <group string="Vendor Commission">
                            <field name="vendor_commission_pct"
                                   string="Vendor Commission (%)"
                                   readonly="state in ('revoked', 'closed')"/>
                            <field name="vendor_commission_amount" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
