<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Multi-company security rule for contact types -->
    <!-- This rule ensures:
         1. Global contact types (company_id=False) are visible in all companies
         2. Company-specific contact types are only visible in their company
    -->
    <data noupdate="1">
        <record id="sor_contact_type_rule_multi_company" model="ir.rule">
            <field name="name">SOR Contact Type multi-company</field>
            <field name="model_id" ref="model_sor_contact_type"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>

