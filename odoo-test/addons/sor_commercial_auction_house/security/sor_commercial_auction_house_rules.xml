<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Multi-company record rules for new models -->
        <record id="sor_fee_default_company_rule" model="ir.rule">
            <field name="name">SOR Fee Default: Multi-company</field>
            <field name="model_id" ref="model_sor_fee_default"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>
        <record id="sor_buyers_premium_tier_company_rule" model="ir.rule">
            <field name="name">SOR Buyers Premium Tier: Multi-company</field>
            <field name="model_id" ref="model_sor_buyers_premium_tier"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>
    </data>
</odoo>
