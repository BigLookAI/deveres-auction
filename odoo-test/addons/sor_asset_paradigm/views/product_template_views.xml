<?xml version="1.0" encoding="utf-8"?>
<!-- Adds the asset_paradigm field to the product template Inventory tab.
     Hidden when not set so non-paradigm products are unaffected. -->
<odoo>
    <data>

        <record id="view_product_tmpl_asset_paradigm_field"
                model="ir.ui.view">
            <field name="name">product.template.asset.paradigm.field</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                <!-- Inject after categ_id in General Information.
                     Always rendered so the value is queryable regardless of state. -->
                <xpath expr="//page[@name='general_information']//field[@name='categ_id']"
                       position="after">
                    <field name="asset_paradigm"
                           widget="badge"
                           string="Asset Paradigm"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
