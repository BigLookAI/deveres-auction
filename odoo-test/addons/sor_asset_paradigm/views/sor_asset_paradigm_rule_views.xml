<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_sor_asset_paradigm_rule_list" model="ir.ui.view">
        <field name="name">sor.asset.paradigm.rule.list</field>
        <field name="model">sor.asset.paradigm.rule</field>
        <field name="arch" type="xml">
            <list string="Paradigm Rules" create="0" delete="0">
                <field name="paradigm"/>
                <field name="element_key" string="Feature"/>
                <field name="manifestation_count" string="Instances"/>
                <field name="active" string="Suppressed" readonly="1"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_sor_asset_paradigm_rule_form" model="ir.ui.view">
        <field name="name">sor.asset.paradigm.rule.form</field>
        <field name="model">sor.asset.paradigm.rule</field>
        <field name="arch" type="xml">
            <form string="Paradigm Rule" create="0" delete="0">
                <sheet>
                    <group string="Identity">
                        <field name="paradigm" readonly="1"/>
                        <field name="element_key" string="Feature" readonly="1"/>
                    </group>
                    <group string="Rule">
                        <field name="active" string="Suppressed"/>
                        <field name="description"/>
                    </group>
                    <separator string="UI Manifestations"/>
                    <field name="has_static_manifestation" invisible="1"/>
                    <field name="manifestation_ids" readonly="1" nolabel="1">
                        <list string="UI Manifestations" create="0" delete="0">
                            <field name="element_name" string="Element Name"/>
                            <field name="element_key" string="Element Key"/>
                            <field name="ui_element_type" string="Element Type"/>
                            <field name="ui_location" string="UI Location"/>
                            <field name="static_marker" string=" " readonly="1"/>
                        </list>
                    </field>
                    <p class="fst-italic text-muted"
                       invisible="not has_static_manifestation">
                        * Statically suppressed — this element type does not support the
                        runtime toggle. The Suppressed checkbox above does not affect it.
                        The suppression is applied when the module is installed and is
                        only reversed by removing the module or running a module upgrade
                        after changing the data.
                    </p>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_sor_asset_paradigm_rule" model="ir.actions.act_window">
        <field name="name">Paradigm Rules</field>
        <field name="res_model">sor.asset.paradigm.rule</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'active_test': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No paradigm rules yet.
            </p>
            <p>
                Rules are installed automatically by asset type bridge modules.
                Uncheck <strong>Suppressed</strong> on a rule to temporarily re-enable
                that UI element for debugging. Refresh the page after toggling.
            </p>
        </field>
    </record>

    <menuitem
        id="menu_sor_asset_paradigm_rules"
        name="Paradigm Rules"
        parent="sor_technical_menu.menu_sor_technical_root"
        action="action_sor_asset_paradigm_rule"
        groups="base.group_no_one"
        sequence="10"/>

</odoo>
