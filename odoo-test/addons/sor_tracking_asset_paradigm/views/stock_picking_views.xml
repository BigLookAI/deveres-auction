<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_picking_form_sor_tracking_asset_paradigm" model="ir.ui.view">
        <field name="name">stock.picking.form.sor_tracking_asset_paradigm</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="sor_tracking.view_picking_form_sor_tracking"/>
        <field name="arch" type="xml">

            <!-- Declare sor_all_unique_objects in arch so view renderer can
                 resolve it in column_invisible expressions on the lines list -->
            <xpath expr="//field[@name='sor_movement_hint']" position="before">
                <field name="sor_all_unique_objects" invisible="1"/>
            </xpath>

            <!-- Suppress Demand column when all lines are unique objects.
                 Staff interact with serial number assignment instead of qty. -->
            <xpath expr="//field[@name='product_uom_qty']" position="attributes">
                <attribute name="column_invisible">parent.sor_all_unique_objects</attribute>
            </xpath>

            <!-- Suppress Quantity column when all lines are unique objects.
                 Preserves existing state=='draft' suppression via 'or'. -->
            <xpath expr="//field[@name='quantity'][@column_invisible]" position="attributes">
                <attribute name="column_invisible">parent.state == 'draft' or parent.sor_all_unique_objects</attribute>
            </xpath>

            <!-- Suppress Shipping Policy — not meaningful for artwork movements -->
            <xpath expr="//field[@name='move_type']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

        </field>
    </record>

    <!-- Suppress Demand group in the Detailed Operations dialog (stock.move form)
         when every product in the picking is a unique object. -->
    <record id="view_stock_move_operations_sor_tracking_asset_paradigm" model="ir.ui.view">
        <field name="name">stock.move.operations.form.sor_tracking_asset_paradigm</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_stock_move_operations"/>
        <field name="arch" type="xml">

            <!-- Declare sor_all_unique_objects so the invisible expression can resolve it -->
            <xpath expr="//group[@name='product_qty']" position="before">
                <field name="sor_all_unique_objects" invisible="1"/>
            </xpath>

            <!-- Hide Demand group for all-unique-object movements -->
            <xpath expr="//group[@name='product_qty']" position="attributes">
                <attribute name="invisible">sor_all_unique_objects</attribute>
            </xpath>

        </field>
    </record>

    <!-- Suppress Quantity column in the Detailed Operations dialog inner line list
         when every product in the picking is a unique object.
         parent.sor_all_unique_objects reads from the enclosing stock.move form. -->
    <record id="view_stock_move_line_operation_tree_sor_tracking_asset_paradigm" model="ir.ui.view">
        <field name="name">stock.move.line.operations.list.sor_tracking_asset_paradigm</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_stock_move_line_operation_tree"/>
        <field name="arch" type="xml">

            <!-- Suppress Quantity column for all-unique-object movements.
                 quantity is the only field with this name in this view. -->
            <xpath expr="//field[@name='quantity']" position="attributes">
                <attribute name="column_invisible">parent.sor_all_unique_objects</attribute>
            </xpath>

        </field>
    </record>

</odoo>
