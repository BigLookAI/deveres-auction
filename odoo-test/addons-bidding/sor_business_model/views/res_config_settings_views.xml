<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add Business Model block inside General Settings -->
    <record id="sor_business_model_config_settings_view" model="ir.ui.view">
        <field name="name">sor.business.model.config.settings</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='companies_setting_container']" position="after">
                <block title="Business Model" name="sor_business_model_setting_container">
                    <setting string="Business Model"
                             help="Governs which commerce fields are suppressed for products in this company.">
                        <field name="business_model"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

</odoo>
