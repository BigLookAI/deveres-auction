<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Fully bespoke, standalone buyer invoice PDF template — dispatched to via
         account.move._get_name_invoice_report() (see models/account_move.py) rather
         than inheriting account.report_invoice_document. Replaces the previous
         inherit-and-patch approach (title override + native table/totals suppression),
         which is fragile because most of the native template's own behaviour was being
         overridden away anyway. Only ever rendered for invoices with sor_event_id set —
         all other invoices continue to use Odoo's native, unmodified template. -->
    <template id="report_invoice_document_sor_buyer_invoice">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <!-- font-size:0.9em set once here, anchored on the lot breakdown table's own
                         size — every templated block below (address, invoice info, tables,
                         statutory notice, regulatory footer) inherits it rather than each
                         declaring its own font-size. Headings (h3) are unaffected: Bootstrap sizes
                         them in rem, not em, so they don't compound off this ancestor value. -->
                    <div class="page" style="font-size:0.9em;">
                        <!-- Title as a plain <h3>, not layout_document_title: this template
                             wraps its own separate web.html_container/docs loop (see the
                             t-call/t-foreach above) before calling web.external_layout, so it is
                             double-nested relative to the outer dispatch loop in
                             account.report_invoice. Confirmed via shell render that
                             layout_document_title set in this inner scope never reaches
                             external_layout's own <h2 t-out="layout_document_title"/> in that
                             double-nested chain — it renders as no tag at all. Reworking the
                             double-wrap is out of scope here, so the title is rendered directly
                             instead. mt-0 keeps it flush under the company header block. -->
                        <h3 class="mt-0">
                            <t t-if="o.move_type == 'out_invoice' and o.state == 'posted'">Invoice</t>
                            <t t-elif="o.move_type == 'out_invoice' and o.state == 'draft'">Draft Invoice</t>
                            <t t-elif="o.move_type == 'out_invoice' and o.state == 'cancel'">Cancelled Invoice</t>
                            <t t-elif="o.move_type == 'out_refund' and o.state == 'posted'">Credit Note</t>
                            <t t-elif="o.move_type == 'out_refund' and o.state == 'draft'">Draft Credit Note</t>
                            <t t-elif="o.move_type == 'out_refund' and o.state == 'cancel'">Cancelled Credit Note</t>
                        </h3>

                        <div class="row mb-4">
                            <div class="col-6">
                                <!-- Buyer Reference — matches PSA's Seller Reference placement
                                     exactly (immediately before the party name). partner_id.ref
                                     is native res.partner; no new dependency (BUG-04). -->
                                <t t-if="o.partner_id.ref">
                                    <strong>Buyer Reference:</strong> <t t-out="o.partner_id.ref"/><br/>
                                </t>
                                <strong t-out="o.partner_id.name"/><br/>
                                <t t-if="o.partner_id.street">
                                    <t t-out="o.partner_id.street"/><br/>
                                </t>
                                <t t-if="o.partner_id.street2">
                                    <t t-out="o.partner_id.street2"/><br/>
                                </t>
                                <!-- No whitespace between these t-if blocks: newline/indentation
                                     text nodes between elements survive QWeb's removal of a
                                     false t-if and render as a stray space (e.g. "Annestown ,
                                     X92Y2W0" when state_id is unset). Kept on one line. -->
                                <t t-if="o.partner_id.city"><t t-out="o.partner_id.city"/></t><t t-if="o.partner_id.state_id"><t t-if="o.partner_id.city">, </t><t t-out="o.partner_id.state_id.name"/></t><t t-if="o.partner_id.zip"><t t-if="o.partner_id.city or o.partner_id.state_id">, </t><t t-out="o.partner_id.zip"/></t>
                                <t t-if="o.partner_id.vat">
                                    <br/><strong>VAT:</strong> <t t-out="o.partner_id.vat"/>
                                </t>
                            </div>
                            <!-- col-5 offset-1 (not col-6): matches the company_address column
                                 position in web.external_layout_bold (deVeres's configured report
                                 layout — see addons/web/views/report_templates.xml:428) so this
                                 column's left edge lines up with the company header's address
                                 block above it. Other layout styles position company_address
                                 differently (e.g. striped/folder use non-grid width classes); if
                                 a future company on a different layout style needs the same
                                 alignment, this offset will need revisiting for that layout. -->
                            <div class="col-5 offset-1">
                                <strong>Invoice No.:</strong> <t t-out="o.name"/><br/>
                                <t t-if="o.invoice_date">
                                    <strong>Invoice Date:</strong>
                                    <t t-out="o.invoice_date" t-options="{'widget': 'date'}"/><br/>
                                </t>
                                <!-- Due Date is suppressed when it is identical to the Invoice
                                     Date — always true with no Payment Terms or an Immediate
                                     Payment term, where showing it is redundant (BUG-04). -->
                                <t t-if="o.invoice_date_due and o.invoice_date_due != o.invoice_date">
                                    <strong>Due Date:</strong>
                                    <t t-out="o.invoice_date_due" t-options="{'widget': 'date'}"/><br/>
                                </t>
                                <!-- Auction context — base sor_events fields only (name,
                                     date_end); no sale_number reference, which is added by
                                     sor_events_auction and would break the Group 1 standalone
                                     case (BUG-04). -->
                                <t t-if="o.sor_event_id">
                                    <strong>Auction:</strong> <t t-out="o.sor_event_id.name"/><br/>
                                    <t t-if="o.sor_event_id.date_end">
                                        <strong>Closing Date:</strong>
                                        <t t-out="o.sor_event_id.date_end" t-options="{'widget': 'date'}"/><br/>
                                    </t>
                                </t>
                            </div>
                        </div>

                        <!-- Generic fallback line-items table — replaced by the lot breakdown
                             table when sor_buyer_invoice_auction_house is installed (see that
                             module's report_invoice_document_sor_auction_house_bridge template,
                             which replaces this entire div). Only rendered here in the Group 1
                             standalone composability case. -->
                        <div name="sor_invoice_line_table">
                            <!-- o_ignore_layout_styling: the company's active report table style
                                 (o_table_bold/o_table_boxed in web/report_tables.scss) doubles
                                 cell padding on every table in every report for this company,
                                 overriding table-sm's own compact padding via ancestor-scoped CSS.
                                 This class is the native escape hatch that opts our own tables out
                                 of that override, keeping table-sm's spacing intact. -->
                            <table class="table table-sm o_main_table o_ignore_layout_styling">
                                <thead>
                                    <tr>
                                        <th>Description</th>
                                        <th class="text-end">Quantity</th>
                                        <th class="text-end">Unit Price</th>
                                        <th class="text-end">Subtotal</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.invoice_line_ids" t-as="line">
                                        <tr>
                                            <td><span t-out="line.name"/></td>
                                            <td class="text-end"><span t-out="line.quantity"/></td>
                                            <td class="text-end">
                                                <span t-out="line.price_unit"
                                                      t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                            </td>
                                            <td class="text-end">
                                                <span t-out="line.price_subtotal"
                                                      t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="3" class="text-end">Untaxed Amount</td>
                                        <td class="text-end">
                                            <span t-out="o.amount_untaxed"
                                                  t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td colspan="3" class="text-end">Tax</td>
                                        <td class="text-end">
                                            <span t-out="o.amount_tax"
                                                  t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                        </td>
                                    </tr>
                                    <tr class="fw-bold">
                                        <td colspan="3" class="text-end">Total</td>
                                        <td class="text-end">
                                            <span t-out="o.amount_total"
                                                  t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        <!-- Payment status: mirrors native Odoo's own print_with_payments block
                             (account/views/report_invoice.xml) so a posted invoice can be reprinted
                             showing it has been paid. Placed outside the replaceable
                             sor_invoice_line_table div (position="replace" only touches that div),
                             so it renders identically whether or not sor_buyer_invoice_auction_house
                             is installed (Group 1 fallback and Group 2 bridge alike, BUG-01). -->
                        <t t-if="o.payment_state != 'invoicing_legacy'">
                            <t t-set="payments_vals"
                               t-value="o.sudo().invoice_payments_widget and o.sudo().invoice_payments_widget['content'] or []"/>
                            <div class="row" name="sor_invoice_payment_status" t-if="payments_vals">
                                <div class="col-6 offset-6">
                                    <!-- table-sm matches the lot breakdown/totals table's row
                                         spacing; font-size inherits the 0.9em set on div.page
                                         above, so it stays anchored to one source of truth rather
                                         than repeating the value here. o_ignore_layout_styling: see
                                         the note on the fallback table above — same escape hatch
                                         from the company's report-style padding override. Payment
                                         line rows are not bold — only Amount Due keeps fw-bold,
                                         same convention as Total Hammer/Total Buyer's
                                         Premium/Invoice Total. -->
                                    <table class="table table-sm table-borderless mb-0 o_ignore_layout_styling">
                                        <t t-foreach="payments_vals" t-as="payment_vals">
                                            <tr t-if="payment_vals['is_exchange'] == 0">
                                                <td>
                                                    <t t-if="payment_vals['is_refund']">Reversed on </t>
                                                    <t t-else="">Paid on </t>
                                                    <t t-out="payment_vals['date']" t-options="{'widget': 'date'}"/>
                                                </td>
                                                <td t-out="payment_vals['payment_method_name']"/>
                                                <td class="text-end">
                                                    <span t-out="payment_vals['amount']"
                                                          t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                            </tr>
                                        </t>
                                        <tr class="fw-bold">
                                            <td colspan="2">Amount Due</td>
                                            <td class="text-end">
                                                <span t-field="o.amount_residual"/>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </t>

                        <!-- Statutory notice anchor — empty by default (Group 1 standalone).
                             sor_buyer_invoice_auction_house's bridge replaces this with the
                             margin-scheme VAT notice when applicable. Positioned after the
                             payment-status block and before the regulatory footer so the
                             notice always renders last, per PO requirement (BUG-02). -->
                        <div name="sor_statutory_notice"/>

                        <!-- Regulatory footer: PSRA licence no., company registration no., VAT no.,
                             bank details. Anchor name="sor_auction_footer" preserved unchanged —
                             sor_buyer_invoice_auction_house's bridge template XPaths this div. -->
                        <t t-if="o.sor_event_id">
                            <div class="mt-4" name="sor_auction_footer">
                                <div class="row">
                                    <div class="col-6" t-if="o.company_id.bank_ids">
                                        <strong>Bank Details</strong>
                                        <t t-foreach="o.company_id.bank_ids" t-as="bank">
                                            <div t-if="bank.acc_number">
                                                <t t-if="bank.bank_id">
                                                    <span t-out="bank.bank_id.name"/>:
                                                </t>
                                                IBAN: <span t-out="bank.acc_number"/>
                                            </div>
                                        </t>
                                    </div>
                                    <div class="col-6">
                                        <t t-if="o.company_id.auction_psra_number">
                                            <div>
                                                <strong>PSRA Licence No.:</strong>
                                                <span t-out="o.company_id.auction_psra_number"/>
                                            </div>
                                        </t>
                                        <t t-if="o.company_id.company_registry">
                                            <div>
                                                <strong>Company Reg. No.:</strong>
                                                <span t-out="o.company_id.company_registry"/>
                                            </div>
                                        </t>
                                        <t t-if="o.company_id.vat">
                                            <div>
                                                <strong>VAT No.:</strong>
                                                <span t-out="o.company_id.vat"/>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- Report-dispatch extension point: account.move._get_name_invoice_report() (above)
         returns this template's id for event-linked invoices. account.report_invoice's own
         dispatch only recognises account.report_invoice_document by default (per its own
         docstring, this method exists precisely so localizations/extensions can add a
         branch here — see l10n_ar for the same pattern). Non-event invoices are entirely
         unaffected: they never reach this t-elif branch. -->
    <template id="report_invoice" inherit_id="account.report_invoice">
        <xpath expr='//t[@t-call="account.report_invoice_document"]' position="after">
            <t t-elif="o._get_name_invoice_report() == 'sor_buyer_invoice.report_invoice_document_sor_buyer_invoice'"
               t-call="sor_buyer_invoice.report_invoice_document_sor_buyer_invoice" t-lang="lang"/>
        </xpath>
    </template>
</odoo>
