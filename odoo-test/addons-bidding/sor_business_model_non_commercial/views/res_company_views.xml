<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Suppress VAT and Company ID fields on the Company form when the company
         has a non_commercial business model. These fields are not relevant for
         non-commercial institutions (universities, museums, permanent collections).
         Currency is intentionally left visible — it is required for Odoo to operate.
         Uses business_model directly (a field on res.company itself) rather than
         going through the rules table, since the record IS the company. -->
    <record id="view_company_form_non_commercial_suppress" model="ir.ui.view">
        <field name="name">res.company.form.non_commercial.suppress</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">

            <!-- Inject business_model into the arch so it can be used in invisible expressions -->
            <xpath expr="//field[@name='name']" position="before">
                <field name="business_model" invisible="1"/>
            </xpath>

            <!-- VAT -->
            <xpath expr="//field[@name='vat']" position="attributes">
                <attribute name="invisible">business_model == 'non_commercial'</attribute>
            </xpath>

            <!-- Company ID (company_registry) -->
            <xpath expr="//field[@name='company_registry']" position="attributes">
                <attribute name="invisible">business_model == 'non_commercial'</attribute>
            </xpath>

        </field>
    </record>

</odoo>
