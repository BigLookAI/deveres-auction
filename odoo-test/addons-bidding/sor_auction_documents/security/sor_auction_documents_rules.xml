<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="sor_pre_sale_advice_company_rule" model="ir.rule">
            <field name="name">SOR Pre-Sale Advice: Multi-company</field>
            <field name="model_id" ref="model_sor_pre_sale_advice"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>
        <record id="sor_vendor_settlement_company_rule" model="ir.rule">
            <field name="name">SOR Vendor Settlement: Multi-company</field>
            <field name="model_id" ref="model_sor_vendor_settlement"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>
        <record id="sor_post_sale_advice_company_rule" model="ir.rule">
            <field name="name">SOR Post-Sale Advice: Multi-company</field>
            <field name="model_id" ref="model_sor_post_sale_advice"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>
    </data>
</odoo>
