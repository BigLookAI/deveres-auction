<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sor_fixed_charge_type_view_list" model="ir.ui.view">
        <field name="name">sor.fixed.charge.type.list</field>
        <field name="model">sor.fixed.charge.type</field>
        <field name="arch" type="xml">
            <list string="Fixed Charge Types">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="sor_fixed_charge_type_view_form" model="ir.ui.view">
        <field name="name">sor.fixed.charge.type.form</field>
        <field name="model">sor.fixed.charge.type</field>
        <field name="arch" type="xml">
            <form string="Fixed Charge Type">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- context active_test=False so archived types remain visible to staff
         managing the list — this is auctioneer-facing configuration, not a
         developer rule list, but the same visibility need applies. -->
    <record id="action_sor_fixed_charge_type" model="ir.actions.act_window">
        <field name="name">Fixed Charge Types</field>
        <field name="res_model">sor.fixed.charge.type</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'active_test': False}</field>
    </record>

    <!-- No existing "Configuration" menu grouping was found for auction house
         settings (checked sor_events_auction, sor_commercial_auction_house) —
         fee-related config (sor.fee.default, sor.buyers.premium.tier) is
         edited inline in Settings, not via a dedicated menu. sor.contact.type
         is the closest precedent but lives under Settings > Technical > SOR,
         which is explicitly the wrong place for auctioneer-facing config.
         A new Configuration grouping under the Auctions root menu follows
         standard Odoo app navigation (e.g. Sales > Configuration). -->
    <menuitem
        id="menu_sor_auctions_configuration"
        name="Configuration"
        parent="sor_events_auction.menu_sor_auctions_root"
        sequence="100"/>

    <menuitem
        id="menu_sor_fixed_charge_type"
        name="Fixed Charge Types"
        parent="menu_sor_auctions_configuration"
        action="action_sor_fixed_charge_type"
        sequence="10"/>
</odoo>
